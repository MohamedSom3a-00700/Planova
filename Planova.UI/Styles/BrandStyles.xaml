<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui">

    <Style x:Key="WorkspaceTabStyle" TargetType="TabItem">
        <Setter Property="Background" Value="{DynamicResource ThemeSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}" />
        <Setter Property="BorderThickness" Value="0,0,0,2" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextSecondary}" />
        <Setter Property="FontFamily" Value="{DynamicResource BrandFontFamily}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter ContentSource="Header"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Border" Property="Background"
                                    Value="{DynamicResource ThemeCard}" />
                            <Setter TargetName="Border" Property="BorderBrush"
                                    Value="{DynamicResource ThemeAccent}" />
                            <Setter Property="Foreground"
                                    Value="{DynamicResource BrandHeaderForeground}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background"
                                    Value="{DynamicResource ThemeCard}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource ThemeSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource BrandRadiusMedium}" />
    </Style>

    <Style x:Key="AIAssistantPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BrandElevationLow}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderSubtle}" />
        <Setter Property="BorderThickness" Value="1,0,0,0" />
        <Setter Property="Width" Value="320" />
    </Style>

    <Style x:Key="AIAssistantCollapsedStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource ThemeAccent}" />
        <Setter Property="Width" Value="48" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="SectionHeaderBaseStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource BrandSubheaderSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource BrandHeaderForeground}" />
        <Setter Property="FontFamily" Value="{DynamicResource BrandFontFamily}" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock"
           BasedOn="{StaticResource SectionHeaderBaseStyle}">
        <Setter Property="Margin" Value="0,16,0,8" />
    </Style>

    <Style x:Key="BodyTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource BrandBodySize}" />
        <Setter Property="Foreground" Value="{DynamicResource BrandHeaderForeground}" />
        <Setter Property="FontFamily" Value="{DynamicResource BrandFontFamily}" />
    </Style>

    <Style x:Key="CardSurfaceStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource ThemeCard}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource BrandRadiusMedium}" />
    </Style>

    <Style x:Key="KpiCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource ThemeCard}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource BrandRadiusMedium}" />
        <Setter Property="Width" Value="200" />
        <Setter Property="Height" Value="120" />
        <Setter Property="Margin" Value="0,0,16,16" />
        <Style.Triggers>
            <EventTrigger RoutedEvent="Mouse.MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <ColorAnimation Storyboard.TargetProperty="BorderBrush.(SolidColorBrush.Color)"
                                        To="#00BFFF" Duration="0:0:0.2" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="Mouse.MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <ColorAnimation Storyboard.TargetProperty="BorderBrush.(SolidColorBrush.Color)"
                                        Duration="0:0:0.2" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="KpiValueStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource ThemeAccent}" />
        <Setter Property="FontFamily" Value="{DynamicResource BrandFontFamily}" />
    </Style>

    <Style x:Key="KpiLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource BrandBodySize}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextSecondary}" />
        <Setter Property="FontFamily" Value="{DynamicResource BrandFontFamily}" />
    </Style>

    <Style x:Key="ActionTileStyle" TargetType="Button">
        <Setter Property="Height" Value="32" />
        <Setter Property="Width" Value="120" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="Foreground" Value="{DynamicResource BrandHeaderForeground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccent}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="{DynamicResource BrandFontFamily}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Name="RootBorder"
                            Background="{DynamicResource BrandElevationLow}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource BrandRadiusSmall}"
                            Padding="12,0">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="RootBorder" Property="Background"
                                    Value="{DynamicResource ThemeAccent}" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="RootBorder" Property="Background"
                                    Value="{DynamicResource BrandAccentPressed}" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DashboardTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource BrandHeaderSize}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource BrandHeaderForeground}" />
        <Setter Property="FontFamily" Value="{DynamicResource BrandFontFamily}" />
    </Style>

    <Style x:Key="EmptyStateContainerStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource ThemeSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource BrandRadiusMedium}" />
        <Setter Property="Padding" Value="{DynamicResource BrandSpacingLarge}" />
        <Setter Property="Margin" Value="{DynamicResource BrandSpacingMedium}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="MinWidth" Value="280" />
        <Setter Property="MaxWidth" Value="400" />
    </Style>

    <Style x:Key="EmptyStateIconStyle" TargetType="ui:SymbolIcon">
        <Setter Property="FontSize" Value="48" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextSecondary}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <Style x:Key="EmptyStateTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource BrandSubheaderSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource BrandHeaderForeground}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="FontFamily" Value="{DynamicResource BrandFontFamily}" />
    </Style>

    <Style x:Key="EmptyStateDescriptionStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource BrandBodySize}" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextSecondary}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="{DynamicResource BrandFontFamily}" />
    </Style>

    <Style TargetType="ScrollViewer">
        <Setter Property="PanningMode" Value="VerticalOnly" />
        <Setter Property="CanContentScroll" Value="True" />
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="10" />
        <Setter Property="Height" Value="10" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextSecondary}" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource ThemeCard}" />
        <Setter Property="Foreground" Value="{DynamicResource BrandHeaderForeground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="FontFamily" Value="{DynamicResource BrandFontFamily}" />
        <Setter Property="CaretBrush" Value="{DynamicResource ThemeAccent}" />
    </Style>

</ResourceDictionary>
