<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <LinearGradientBrush x:Key="ShellBackgroundGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#0D1117" />
        <GradientStop Offset="1" Color="#161B22" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="DashboardBackgroundGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#0D1117" />
        <GradientStop Offset="0.6" Color="#1F2937" />
        <GradientStop Offset="1" Color="#161B22" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="WorkspaceBackgroundGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#161B22" />
        <GradientStop Offset="1" Color="#1F2937" />
    </LinearGradientBrush>

</ResourceDictionary>