<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="ThemeBackground" Color="#0D1117" />
    <SolidColorBrush x:Key="ThemeForeground" Color="#E0E0E0" />
    <SolidColorBrush x:Key="ThemeSurface" Color="#161B22" />
    <SolidColorBrush x:Key="ThemeCard" Color="#1F2937" />
    <SolidColorBrush x:Key="ThemeBorder" Color="#2A3441" />
    <SolidColorBrush x:Key="ThemeAccent" Color="#00BFFF" />
    <SolidColorBrush x:Key="ThemeSecondaryAccent" Color="#0078D4" />

    <SolidColorBrush x:Key="BrandChromeSurface" Color="#161B22" />
    <SolidColorBrush x:Key="BrandChromeForeground" Color="#E0E0E0" />

    <SolidColorBrush x:Key="BrandSurfaceDark" Color="#161B22" />
    <SolidColorBrush x:Key="BrandSurfaceLight" Color="#FFFFFF" />
    <SolidColorBrush x:Key="BrandElevationLow" Color="#2A2A3E" />
    <SolidColorBrush x:Key="BrandElevationMedium" Color="#32324A" />
    <SolidColorBrush x:Key="BrandElevationLowLight" Color="#FFFFFF" />
    <SolidColorBrush x:Key="BrandElevationMediumLight" Color="#F0F0F0" />
    <SolidColorBrush x:Key="BrandHeaderForeground" Color="#E0E0E0" />
    <SolidColorBrush x:Key="BrandHeaderForegroundLight" Color="#1A1A1A" />
    <SolidColorBrush x:Key="BrandBorderDefault" Color="#2A3441" />
    <SolidColorBrush x:Key="BrandBorderSubtle" Color="#1F2937" />
    <SolidColorBrush x:Key="BrandBorderLight" Color="#D6DCE5" />
    <SolidColorBrush x:Key="BrandTextSecondary" Color="#9E9E9E" />
    <SolidColorBrush x:Key="BrandTextSecondaryLight" Color="#5C5C5C" />

    <LinearGradientBrush x:Key="ShellBackgroundGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#0D1117" />
        <GradientStop Offset="1" Color="#161B22" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="DashboardBackgroundGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#0D1117" />
        <GradientStop Offset="0.6" Color="#1F2937" />
        <GradientStop Offset="1" Color="#161B22" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="WorkspaceBackgroundGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#161B22" />
        <GradientStop Offset="1" Color="#1F2937" />
    </LinearGradientBrush>

</ResourceDictionary>
