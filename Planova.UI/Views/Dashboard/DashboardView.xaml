<UserControl x:Class="Planova.UI.Views.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels"
             xmlns:conv="clr-namespace:Planova.UI.Converters"
             d:DataContext="{d:DesignInstance vm:DashboardViewModel}"
             mc:Ignorable="d"
             Background="{DynamicResource DashboardBackgroundGradient}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <ScrollViewer>
        <StackPanel Margin="{DynamicResource BrandSpacingLarge}">
            <TextBlock Text="Dashboard"
                       Style="{StaticResource DashboardTitleStyle}"/>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource BrandDanger}"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                       Margin="0,8,0,0"/>

            <WrapPanel Margin="0,24,0,0">
                <Border Style="{StaticResource KpiCardStyle}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding TotalProjects}"
                                   Style="{StaticResource KpiValueStyle}"/>
                        <TextBlock Text="Projects"
                                   Style="{StaticResource KpiLabelStyle}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource KpiCardStyle}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding TotalClients}"
                                   Style="{StaticResource KpiValueStyle}"/>
                        <TextBlock Text="Clients"
                                   Style="{StaticResource KpiLabelStyle}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource KpiCardStyle}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding TotalContracts}"
                                   Style="{StaticResource KpiValueStyle}"/>
                        <TextBlock Text="Contracts"
                                   Style="{StaticResource KpiLabelStyle}"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <TextBlock Text="Status Distribution" Style="{StaticResource SectionHeaderStyle}"/>
            <TextBlock Text="{Binding StatusDistributionSummary}"
                       Style="{StaticResource BodyTextStyle}"
                       TextWrapping="Wrap" Margin="0,0,0,16"/>

            <TextBlock Text="Quick Actions" Style="{StaticResource SectionHeaderStyle}"/>
            <StackPanel Orientation="Horizontal">
                <Button Content="+ New Project" Command="{Binding NavigateToProjectsCommand}"
                        Style="{StaticResource ActionTileStyle}"/>
                <Button Content="+ New Client" Command="{Binding NavigateToClientsCommand}"
                        Style="{StaticResource ActionTileStyle}"/>
                <Button Content="+ New Contract" Command="{Binding NavigateToContractsCommand}"
                        Style="{StaticResource ActionTileStyle}"/>
            </StackPanel>

            <TextBlock Text="Recent Activity" Style="{StaticResource SectionHeaderStyle}" Margin="0,24,0,8"/>
            <Border Style="{StaticResource CardSurfaceStyle}" MaxHeight="300">
                <ListView ItemsSource="{Binding RecentActivity}"
                          BorderThickness="0">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="{Binding EntityType}" FontWeight="SemiBold" Width="80"
                                           Foreground="{DynamicResource BrandHeaderForeground}"
                                           FontFamily="{DynamicResource BrandFontFamily}"/>
                                <TextBlock Text="{Binding EntityName}" Width="200"
                                           Foreground="{DynamicResource BrandHeaderForeground}"
                                           FontFamily="{DynamicResource BrandFontFamily}"/>
                                <TextBlock Text="{Binding Action}" Width="80"
                                           Foreground="{DynamicResource BrandTextSecondary}"
                                           FontFamily="{DynamicResource BrandFontFamily}"/>
                                <TextBlock Text="{Binding Timestamp, StringFormat={}{0:g}}"
                                           Foreground="{DynamicResource BrandTextSecondary}"
                                           FontFamily="{DynamicResource BrandFontFamily}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
