<UserControl x:Class="Planova.UI.Views.Boq.BoqImportWizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Import BOQ" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,8">
                <TextBlock Text="{Binding StatusMessage}" Margin="0,0,0,8"/>
                <Button Content="Select File" Command="{Binding SelectFileCommand}" Margin="0,0,0,8" MinWidth="120"/>

                <GroupBox Header="Sheet Selection" Margin="0,0,0,8"
                          Visibility="{Binding IsExcel, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <CheckBox Content="Merge all sheets" IsChecked="{Binding MergeAllSheets}"
                                  Margin="0,0,0,4"/>
                        <Grid IsEnabled="{Binding MergeAllSheets, Converter={StaticResource InverseBoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Sheet:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableWorksheets}"
                                      SelectedItem="{Binding SelectedWorksheet}"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Column Mapping" Margin="0,8,0,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Code:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding DetectedColumns}"
                                  Text="{Binding CodeColumn}" IsEditable="True" Margin="0,0,0,3"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Description:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding DetectedColumns}"
                                  Text="{Binding DescriptionColumn}" IsEditable="True" Margin="0,0,0,3"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Unit:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding DetectedColumns}"
                                  Text="{Binding UnitColumn}" IsEditable="True" Margin="0,0,0,3"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Quantity:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="3" Grid.Column="1" ItemsSource="{Binding DetectedColumns}"
                                  Text="{Binding QuantityColumn}" IsEditable="True" Margin="0,0,0,3"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Rate:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="4" Grid.Column="1" ItemsSource="{Binding DetectedColumns}"
                                  Text="{Binding RateColumn}" IsEditable="True" Margin="0,0,0,3"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Classification:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="5" Grid.Column="1" ItemsSource="{Binding DetectedColumns}"
                                  Text="{Binding ClassificationColumn}" IsEditable="True" Margin="0,0,0,3"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="CSI Division:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="6" Grid.Column="1" ItemsSource="{Binding DetectedColumns}"
                                  Text="{Binding DivisionColumn}" IsEditable="True" Margin="0,0,0,3"/>
                    </Grid>
                </GroupBox>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Preview" Command="{Binding PreviewImportCommand}" Margin="0,0,8,0" MinWidth="80"/>
                    <Button Content="Import" Command="{Binding CommitImportCommand}" CommandParameter="{Binding CurrentProjectId}" MinWidth="80"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <ProgressBar Grid.Row="3" Height="4" Value="{Binding ProgressValue}" Margin="0,8,0,0"/>
    </Grid>
</UserControl>
