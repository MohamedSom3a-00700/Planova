<UserControl x:Class="Planova.UI.Views.Boq.BoqEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels.Boq"
             xmlns:boqDto="clr-namespace:Planova.Boq.Application.Dto;assembly=Planova.Boq"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Edit BOQ Items" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                <TextBlock Text="Items" FontWeight="Bold" Margin="0,0,0,8"/>
                <ListView ItemsSource="{Binding RootItems}"
                          SelectedItem="{Binding SelectedTreeItem, Mode=TwoWay}"
                          VirtualizingPanel.ScrollUnit="Item"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="No." Width="40" DisplayMemberBinding="{Binding SortOrder}"/>
                            <GridViewColumn Header="Code" Width="80" DisplayMemberBinding="{Binding Code}"/>
                            <GridViewColumn Header="Description" Width="140" DisplayMemberBinding="{Binding Description}"/>
                            <GridViewColumn Header="Qty" Width="60" DisplayMemberBinding="{Binding Quantity, StringFormat='N2'}"/>
                            <GridViewColumn Header="Rate" Width="60" DisplayMemberBinding="{Binding Rate, StringFormat='N2'}"/>
                            <GridViewColumn Header="Amount" Width="70" DisplayMemberBinding="{Binding Amount, StringFormat='N2'}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </StackPanel>

            <StackPanel Grid.Column="1" Visibility="{Binding HasBoq, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding StatusMessage}" Margin="0,0,0,8"/>

                <GroupBox Header="Code Selector" Margin="0,0,0,8">
                    <ComboBox ItemsSource="{Binding AvailableCodes}"
                              SelectedItem="{Binding EditCode, Mode=TwoWay}"
                              IsEditable="True"
                              DisplayMemberPath="."
                              MinHeight="24"/>
                </GroupBox>

                <GroupBox Header="Item Properties" Margin="0,0,0,8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="320">
                        <StackPanel>
                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="No.:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <TextBox Grid.Column="1" IsReadOnly="True" Text="{Binding ItemSortOrder}"/>
                            </Grid>
                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Code:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <TextBox Grid.Column="1" Text="{Binding EditCode}"/>
                            </Grid>
                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Description:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <TextBox Grid.Column="1" Text="{Binding EditDescription}"/>
                            </Grid>
                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Unit:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <TextBox Grid.Column="1" Text="{Binding EditUnit}"/>
                            </Grid>
                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Quantity:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <TextBox Grid.Column="1" Text="{Binding EditQuantity}"/>
                            </Grid>
                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Rate:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <TextBox Grid.Column="1" Text="{Binding EditRate}"/>
                            </Grid>
                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Cost Code:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <TextBox Grid.Column="1" Text="{Binding EditCostCode}"/>
                            </Grid>
                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Active:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <CheckBox Grid.Column="1" IsChecked="{Binding EditIsActive}" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Item Type:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <TextBox Grid.Column="1" IsReadOnly="True" Text="{Binding ItemTypeDisplay}"/>
                            </Grid>
                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Level:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <TextBox Grid.Column="1" IsReadOnly="True" Text="{Binding ItemLevel}"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </GroupBox>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Update" Command="{Binding UpdateItemCommand}" Margin="0,0,8,0" MinWidth="80"/>
                    <Button Content="Add" Command="{Binding AddItemCommand}" Margin="0,0,8,0" MinWidth="80"/>
                    <Button Content="Delete" Command="{Binding DeleteItemCommand}" Margin="0,0,8,0" MinWidth="80"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
