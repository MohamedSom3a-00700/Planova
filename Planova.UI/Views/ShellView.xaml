<Window x:Class="Planova.UI.Views.ShellView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:Planova.UI.Views"
        mc:Ignorable="d"
        Title="Planova" Height="720" Width="1280"
        Background="{DynamicResource ThemeBackground}"
        Foreground="{DynamicResource ThemeForeground}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <views:NavigationRail x:Name="NavigationRail" Grid.Row="0" Grid.Column="0" />

        <views:WorkspaceArea x:Name="WorkspaceArea" Grid.Row="0" Grid.Column="1" />

        <Border Grid.Row="1" Grid.ColumnSpan="2"
                Background="{DynamicResource ThemeSurface}"
                BorderBrush="{DynamicResource ThemeBorder}"
                BorderThickness="0,1,0,0"
                Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StatusText}" VerticalAlignment="Center" />

                <Button Grid.Column="1" Content="Toggle Theme"
                        Command="{Binding ToggleThemeCommand}"
                        Margin="4,0"
                        Background="{DynamicResource ThemeSurface}"
                        Foreground="{DynamicResource ThemeForeground}"
                        BorderBrush="{DynamicResource ThemeBorder}"
                        BorderThickness="1"
                        Padding="8,2" />

                <Button Grid.Column="2" Content="EN/AR"
                        Command="{Binding ToggleLanguageCommand}"
                        Margin="4,0"
                        Background="{DynamicResource ThemeSurface}"
                        Foreground="{DynamicResource ThemeForeground}"
                        BorderBrush="{DynamicResource ThemeBorder}"
                        BorderThickness="1"
                        Padding="8,2" />
            </Grid>
        </Border>
    </Grid>
</Window>
