<UserControl x:Class="Planova.UI.Views.Wbs.WbsReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="WBS Reports" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TabControl SelectedIndex="{Binding SelectedReportTypeIndex}" Margin="0,0,16,0" MinWidth="300">
                <TabItem Header="Summary Report"/>
                <TabItem Header="Dictionary Report"/>
            </TabControl>
            <Button Content="Load" Command="{Binding LoadSummaryCommand}" Margin="0,0,8,0"
                    Visibility="{Binding IsSummarySelected, Converter={StaticResource BoolToVis}}"/>
            <Button Content="Load" Command="{Binding LoadDictionaryCommand}" Margin="0,0,8,0"
                    Visibility="{Binding IsDictionarySelected, Converter={StaticResource BoolToVis}}"/>
            <Button Content="Export CSV" Command="{Binding ExportExcelCommand}" Margin="0,0,8,0"/>
            <Button Content="Export PDF" Command="{Binding ExportPdfCommand}"/>
        </StackPanel>

        <Border Grid.Row="2" BorderThickness="1" BorderBrush="Gray" CornerRadius="4" Padding="8">
            <Grid>
                <!-- Summary Report View -->
                <Grid Visibility="{Binding IsSummarySelected, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding SummaryReport.WbsName, StringFormat='WBS: {0}'}"
                               FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{Binding SummaryReport.TotalItems, StringFormat='Items: {0}'}" Margin="0,0,16,0"/>
                        <TextBlock Text="{Binding SummaryReport.TotalLevels, StringFormat='Levels: {0}'}" Margin="0,0,16,0"/>
                        <TextBlock Text="{Binding SummaryReport.TotalWeight, StringFormat='Total Weight: {0:F2}%'}"/>
                    </StackPanel>
                    <ListView Grid.Row="3" ItemsSource="{Binding SummarySections}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Level" Width="150" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Items" Width="80" DisplayMemberBinding="{Binding ItemCount}"/>
                                <GridViewColumn Header="Weight %" Width="100" DisplayMemberBinding="{Binding WeightPercentage}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>

                <!-- Dictionary Report View -->
                <Grid Visibility="{Binding IsDictionarySelected, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding DictionaryReport.WbsName, StringFormat='WBS: {0}'}"
                               FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ListView Grid.Row="1" ItemsSource="{Binding DictionaryEntries}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Code" Width="80" DisplayMemberBinding="{Binding Code}"/>
                                <GridViewColumn Header="Name" Width="200" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Level" Width="100" DisplayMemberBinding="{Binding WbsLevel}"/>
                                <GridViewColumn Header="Assigned To" Width="120" DisplayMemberBinding="{Binding AssignedTo}"/>
                                <GridViewColumn Header="Deliverable" Width="150" DisplayMemberBinding="{Binding Deliverable}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Grid>
        </Border>

        <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}" Foreground="Red" Margin="0,8,0,0"
                   Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"/>
    </Grid>
</UserControl>
