<UserControl x:Class="Planova.UI.Views.Wbs.WbsTemplateManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="WBS Template Manager" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderThickness="1" BorderBrush="Gray" CornerRadius="4"
                    Padding="8" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Templates" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ComboBox Grid.Row="1" ItemsSource="{Binding AllCategories}"
                              SelectedItem="{Binding SelectedCategory}" Margin="0,0,0,8"/>
                    <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,0,0,8">
                        <Button Content="Import Template" Command="{Binding ImportTemplateCommand}"
                                Margin="0,0,0,4" MinWidth="100"/>
                        <Button Content="Import from Excel" Command="{Binding ImportFromExcelCommand}"
                                MinWidth="100"/>
                    </StackPanel>
                    <ListBox Grid.Row="3" ItemsSource="{Binding Templates}"
                             SelectedItem="{Binding SelectedTemplate}"
                             DisplayMemberPath="Name"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" BorderThickness="1" BorderBrush="Gray" CornerRadius="4"
                    Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Template Preview" FontSize="16" FontWeight="SemiBold"
                               Margin="0,0,0,4"/>
                    <TextBlock Grid.Row="1" Text="{Binding SelectedTemplate.Description}"
                               Margin="0,0,0,8" TextWrapping="Wrap"/>

                    <TreeView Grid.Row="2" ItemsSource="{Binding TemplateTree}" Margin="0,0,0,8">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Code}" FontWeight="Bold" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Name}" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding WbsLevel}" Foreground="Gray" FontSize="11"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>

                    <StackPanel Grid.Row="3" Orientation="Horizontal">
                        <Button Content="Apply Template" Command="{Binding ApplyTemplateCommand}"
                                Margin="0,0,8,0" MinWidth="100"/>
                        <Button Content="Export Template" Command="{Binding ExportTemplateCommand}"
                                Margin="0,0,8,0" MinWidth="100"/>
                        <Separator Width="1" Background="Gray" Margin="0,0,8,0"/>
                        <TextBox Text="{Binding SaveTemplateName, UpdateSourceTrigger=PropertyChanged}"
                                 MinWidth="120" ToolTip="Template name"/>
                        <TextBox Text="{Binding SaveTemplateCategory, UpdateSourceTrigger=PropertyChanged}"
                                 MinWidth="80" Margin="8,0,8,0" ToolTip="Category"/>
                        <Button Content="Save As Template" Command="{Binding SaveAsTemplateCommand}"
                                MinWidth="100"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="Red" Margin="0,8,0,0"
                   Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"/>
    </Grid>
</UserControl>
