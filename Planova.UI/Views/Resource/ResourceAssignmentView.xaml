<UserControl x:Class="Planova.UI.Views.Resource.ResourceAssignmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels.Resource"
             d:DataContext="{d:DesignInstance vm:ResourceAssignmentViewModel}"
             Background="{DynamicResource WorkspaceBackgroundGradient}"
             FontFamily="{DynamicResource BrandFontFamily}"
             mc:Ignorable="d">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Resource Assignments" FontSize="20" FontWeight="Bold"
                       Foreground="{DynamicResource ThemeForeground}" Margin="0,0,16,0"/>
            <Button Content="Add Assignment" Command="{Binding AddAssignmentCommand}" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <Button Content="Apply Crew" Command="{Binding ApplyCrewCommand}" VerticalAlignment="Center"/>
        </StackPanel>

        <DataGrid Grid.Row="1" x:Name="AssignmentsGrid"
                  ItemsSource="{Binding Assignments}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Background="Transparent"
                  BorderThickness="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Resource" Binding="{Binding ResourceName}" Width="*"/>
                <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="100"/>
                <DataGridTextColumn Header="Unit" Binding="{Binding UnitOfMeasure}" Width="80"/>
                <DataGridTextColumn Header="Rate" Binding="{Binding Rate}" Width="100"/>
                <DataGridTextColumn Header="Total Cost" Binding="{Binding TotalCost}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock Text="{Binding TotalCost, StringFormat='Total: {0:N2}'}"
                       FontSize="16" FontWeight="Bold"
                       Foreground="{DynamicResource ThemeForeground}"
                       VerticalAlignment="Center" Margin="0,0,12,0"/>
            <Button Content="Remove" Command="{Binding RemoveAssignmentCommand}"
                    CommandParameter="{Binding ElementName=AssignmentsGrid, Path=SelectedItem}"/>
        </StackPanel>
    </Grid>
</UserControl>
