<UserControl x:Class="Planova.UI.Views.Resource.ResourceHistogramView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels.Resource"
             d:DataContext="{d:DesignInstance vm:ResourceHistogramViewModel}"
             Background="{DynamicResource WorkspaceBackgroundGradient}"
             FontFamily="{DynamicResource BrandFontFamily}"
             mc:Ignorable="d">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Resource Histogram" FontSize="20" FontWeight="Bold"
                       Foreground="{DynamicResource ThemeForeground}" VerticalAlignment="Center"/>
            <Button Content="Export" Command="{Binding ExportDataCommand}"
                    Margin="16,0,0,0" VerticalAlignment="Center" MinHeight="28"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Select Resource:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
            <ComboBox ItemsSource="{Binding AvailableResources}"
                      SelectedItem="{Binding SelectedResource, Mode=TwoWay}"
                      DisplayMemberPath="Name"
                      Width="240"
                      MinHeight="28"/>
        </StackPanel>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding HistogramData.DailyData}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Background="Transparent"
                  BorderThickness="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="120"/>
                <DataGridTextColumn Header="Quantity" Binding="{Binding TotalQuantity}" Width="120"/>
                <DataGridTextColumn Header="Overallocated" Binding="{Binding IsOverallocated}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="3" Margin="0,8,0,0">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Text" Value=""/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HistogramData}" Value="{x:Null}">
                            <Setter Property="Text" Value="Select a resource to load histogram data"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
    </Grid>
</UserControl>
