<UserControl x:Class="Planova.UI.Views.Resource.CrewTemplateEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels.Resource"
             d:DataContext="{d:DesignInstance vm:CrewTemplateEditorViewModel}"
             Background="{DynamicResource WorkspaceBackgroundGradient}"
             FontFamily="{DynamicResource BrandFontFamily}"
             mc:Ignorable="d">
    <ScrollViewer>
        <StackPanel Margin="12" MaxWidth="600">
            <TextBlock Text="Crew Template Editor" FontSize="20" FontWeight="Bold"
                       Foreground="{DynamicResource ThemeForeground}"/>

            <TextBox Text="{Binding Crew.Name, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="{Binding BlendedRate, StringFormat='Blended Rate: {0:N2}'}"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource ThemeForeground}"/>

            <DataGrid ItemsSource="{Binding Resources}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Background="Transparent"
                      BorderThickness="0"
                       >
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Resource" Binding="{Binding ResourceName}" Width="*"/>
                    <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="100"/>
                    <DataGridTextColumn Header="Line Total" Binding="{Binding LineTotal}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save" Command="{Binding SaveCommand}"/>
                <Button Content="Cancel" Command="{Binding CancelCommand}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
