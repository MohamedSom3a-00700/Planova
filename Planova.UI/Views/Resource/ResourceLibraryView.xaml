<UserControl x:Class="Planova.UI.Views.Resource.ResourceLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels.Resource"
             d:DataContext="{d:DesignInstance vm:ResourceLibraryViewModel}"
             Background="{DynamicResource WorkspaceBackgroundGradient}"
             FontFamily="{DynamicResource BrandFontFamily}"
             mc:Ignorable="d">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                     Width="250" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <Button Content="Search" Command="{Binding SearchCommand}" Margin="0,0,8,0"/>
            <Button Content="Create" Command="{Binding CreateResourceCommand}" Margin="0,0,8,0"/>
            <Button Content="Import" Command="{Binding ImportResourcesCommand}" Margin="0,0,8,0"/>
            <Button Content="Export" Command="{Binding ExportResourcesCommand}"/>
        </StackPanel>

        <Border Grid.Row="1" BorderThickness="1" BorderBrush="Gray" CornerRadius="4" Padding="8"
                Margin="0,0,0,8" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="Resource Editor" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Margin="0,0,8,4" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Type" Margin="0,0,8,4" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" SelectedItem="{Binding EditResourceType}" Margin="0,0,0,4">
                        <ComboBox.ItemsSource>
                            <x:Array Type="sys:Object" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                                     xmlns:enum="clr-namespace:Planova.Resource.Domain.Enums;assembly=Planova.Resource">
                                <enum:ResourceType>Labour</enum:ResourceType>
                                <enum:ResourceType>Equipment</enum:ResourceType>
                                <enum:ResourceType>Material</enum:ResourceType>
                                <enum:ResourceType>Subcontractor</enum:ResourceType>
                            </x:Array>
                        </ComboBox.ItemsSource>
                    </ComboBox>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Scope" Margin="0,0,8,4" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="2" Grid.Column="1" SelectedItem="{Binding EditScope}" Margin="0,0,0,4">
                        <ComboBox.ItemsSource>
                            <x:Array Type="sys:Object" xmlns:sys="clr-namespace:System;assembly=mscorlib"
                                     xmlns:enum="clr-namespace:Planova.Resource.Domain.Enums;assembly=Planova.Resource">
                                <enum:ResourceScope>Project</enum:ResourceScope>
                                <enum:ResourceScope>Global</enum:ResourceScope>
                            </x:Array>
                        </ComboBox.ItemsSource>
                    </ComboBox>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Default Rate" Margin="0,0,8,4" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding EditDefaultRate, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="UOM" Margin="0,0,8,4" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding EditUnitOfMeasure, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Currency" Margin="0,0,8,4" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding EditCurrency, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="Save" Command="{Binding SaveResourceCommand}" Margin="0,0,8,0"/>
                    <Button Content="Cancel" Command="{Binding CancelEditCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Resources}"
                  SelectedItem="{Binding SelectedResource, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Background="Transparent"
                  BorderThickness="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="120"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Type" Binding="{Binding ResourceType}" Width="100"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                <DataGridTextColumn Header="Scope" Binding="{Binding Scope}" Width="80"/>
                <DataGridTextColumn Header="Default Rate" Binding="{Binding DefaultRate}" Width="100"/>
                <DataGridTextColumn Header="UOM" Binding="{Binding UnitOfMeasure}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusMessage}" Margin="0,0,12,0" VerticalAlignment="Center"/>
            <Button Content="Edit" Command="{Binding EditResourceCommand}"
                    CommandParameter="{Binding SelectedResource}" Margin="0,0,8,0"/>
            <Button Content="Deactivate" Command="{Binding DeactivateResourceCommand}"
                    CommandParameter="{Binding SelectedResource}" Margin="0,0,8,0"/>
            <Button Content="Reactivate" Command="{Binding ReactivateResourceCommand}"
                    CommandParameter="{Binding SelectedResource}"/>
        </StackPanel>
    </Grid>
</UserControl>
