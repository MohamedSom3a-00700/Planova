<UserControl x:Class="Planova.UI.Views.Resource.ResourceReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels.Resource"
             xmlns:dto="clr-namespace:Planova.Resource.Application.Dto;assembly=Planova.Resource"
             d:DataContext="{d:DesignInstance vm:ResourceReportViewModel}"
             Background="{DynamicResource WorkspaceBackgroundGradient}"
             FontFamily="{DynamicResource BrandFontFamily}"
             mc:Ignorable="d">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Resource Reports" FontSize="20" FontWeight="Bold"
                   Foreground="{DynamicResource ThemeForeground}" Margin="0,0,0,16"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <ComboBox SelectedItem="{Binding SelectedReportType}" Width="200" Margin="0,0,8,0">
                <ComboBox.ItemsSource>
                    <x:Array Type="sys:Object" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                        <dto:ReportType>UsageSummary</dto:ReportType>
                        <dto:ReportType>CostReport</dto:ReportType>
                    </x:Array>
                </ComboBox.ItemsSource>
            </ComboBox>
            <Button Content="Generate" Command="{Binding GenerateReportCommand}" Margin="0,0,8,0"/>
            <Button Content="Export to Excel" Command="{Binding ExportToExcelCommand}" Margin="0,0,8,0"/>
            <Button Content="Export to PDF" Command="{Binding ExportToPdfCommand}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="2">
            <StackPanel>
                <ContentPresenter Content="{Binding UsageReport}" Visibility="{Binding HasData, Converter={StaticResource BoolToVis}}"/>
                <ContentPresenter Content="{Binding CostReport}" Visibility="{Binding HasData, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
