<UserControl x:Class="Planova.UI.Views.Primavera.PrimaveraImportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels.Primavera"
             xmlns:ui="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:PrimaveraImportViewModel}">
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
  </UserControl.Resources>
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="20,16,12,16">

        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
          <ui:SymbolIcon Symbol="ArrowUpload24" FontSize="20" Margin="0,0,8,0"
                         Foreground="{DynamicResource ThemeForeground}" />
          <StackPanel>
            <TextBlock Text="Import XER File" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="Select a Primavera P6 XER file to import" FontSize="12"
                       Foreground="{DynamicResource BrandTextSecondary}" />
          </StackPanel>
        </StackPanel>

        <Border Background="{DynamicResource ThemeCard}" Padding="16" CornerRadius="6"
                BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Margin="0,0,0,16">
          <StackPanel>
            <TextBlock Text="File Selection" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />
            <StackPanel Orientation="Horizontal">
              <TextBox Text="{Binding SelectedFilePath, Mode=OneWay}"
                       IsReadOnly="True"
                       Width="320"
                       Margin="0,0,8,0" />
              <ui:Button Content="Browse"
                         Command="{Binding BrowseFileCommand}"
                         Appearance="Primary" Width="90" />
            </StackPanel>
          </StackPanel>
        </Border>

        <ProgressBar IsIndeterminate="{Binding IsImporting}"
                     Visibility="{Binding IsImporting, Converter={StaticResource BoolToVis}}"
                     Height="3" Margin="0,0,0,12" />

        <Border Background="{DynamicResource ThemeCard}" Padding="12" CornerRadius="6"
                BorderBrush="{DynamicResource BrandTextSecondary}" BorderThickness="1"
                Visibility="{Binding IsPreviewVisible, Converter={StaticResource BoolToVis}}"
                Margin="0,0,0,16">
          <StackPanel>
            <TextBlock Text="Preview" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <TextBlock Grid.Row="0" Grid.Column="0" Text="File:" FontWeight="SemiBold" />
              <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Preview.FileName}" />
              <TextBlock Grid.Row="1" Grid.Column="0" Text="Size:" FontWeight="SemiBold" />
              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Preview.FileSize, StringFormat='{}{0:N0} bytes'}" />
            </Grid>

            <TextBlock Text="Row Counts" FontWeight="SemiBold" FontSize="13" Margin="0,8,0,4" />
            <ItemsControl ItemsSource="{Binding Preview.RowCounts}" Margin="0,0,0,8">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource ThemeBorder}" Padding="4,3">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="60" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" Text="{Binding Key}" FontSize="12" />
                      <TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="SemiBold"
                                 HorizontalAlignment="Right" FontSize="12" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="Validation Issues" FontWeight="SemiBold" FontSize="13" Margin="0,4,0,4" />
            <ItemsControl ItemsSource="{Binding ValidationIssues}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                    <ui:SymbolIcon Symbol="Warning24" FontSize="14" Foreground="#FFB83B" Margin="0,0,6,0" />
                    <TextBlock Text="{Binding Description}" FontSize="12" TextWrapping="Wrap" />
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,16">
          <ui:Button Content="Commit Import"
                     Command="{Binding CommitImportCommand}"
                     Appearance="Primary"
                     Width="130" Margin="0,0,8,0" />
          <ui:Button Content="Cancel"
                     Command="{Binding CancelImportCommand}"
                     Width="90" />
        </StackPanel>

        <TextBlock Text="Import Log" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8" />
        <ListView ItemsSource="{Binding ImportLog}"
                  MaxHeight="220"
                  Background="{DynamicResource ThemeCard}"
                  BorderThickness="1"
                  BorderBrush="{DynamicResource ThemeBorder}">
          <ListView.ItemTemplate>
            <DataTemplate>
              <Grid Margin="2,2">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="70" />
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Timestamp}"
                           Foreground="{DynamicResource BrandTextSecondary}" FontSize="11" />
                <TextBlock Grid.Column="1" Text="{Binding Severity, StringFormat='[{0}]'}"
                           FontSize="11" FontWeight="SemiBold" Margin="0,0,6,0">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Foreground" Value="{DynamicResource ThemeForeground}" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding Severity}" Value="Warning">
                          <Setter Property="Foreground" Value="#FFB83B" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Severity}" Value="Error">
                          <Setter Property="Foreground" Value="#E81123" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
                <TextBlock Grid.Column="2" Text="{Binding Message}" TextWrapping="Wrap" FontSize="12" />
              </Grid>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </StackPanel>
    </ScrollViewer>

    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" />

    <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="12,16,20,16">
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
          <ui:SymbolIcon Symbol="Database24" FontSize="20" Margin="0,0,8,0"
                         Foreground="{DynamicResource ThemeForeground}" />
          <TextBlock Text="Imported XER Sessions" FontSize="18" FontWeight="SemiBold" />
        </StackPanel>

        <DataGrid ItemsSource="{Binding ImportedSessions}"
                  SelectedItem="{Binding SelectedImportedSession, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  MaxHeight="500"
                  Background="{DynamicResource ThemeCard}"
                  BorderBrush="{DynamicResource ThemeBorder}"
                  BorderThickness="1"
                  RowDetailsVisibilityMode="VisibleWhenSelected"
                  HeadersVisibility="Column"
                  RowHeight="28"
                  FontSize="12">
          <DataGrid.Resources>
            <Style TargetType="DataGridColumnHeader">
              <Setter Property="FontWeight" Value="SemiBold" />
              <Setter Property="Padding" Value="6,3" />
            </Style>
            <Style TargetType="DataGridCell">
              <Setter Property="Padding" Value="6,2" />
            </Style>
          </DataGrid.Resources>
          <DataGrid.Columns>
            <DataGridTextColumn Header="File Name" Binding="{Binding SourceFileName}" Width="*" />
            <DataGridTextColumn Header="Imported At" Binding="{Binding ImportedAt, StringFormat='{}{0:g}'}" Width="130" />
            <DataGridTextColumn Header="By" Binding="{Binding ImportedBy}" Width="90" />
            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="70" />
          </DataGrid.Columns>
          <DataGrid.RowDetailsTemplate>
            <DataTemplate>
              <Border Background="{DynamicResource WorkspaceBackgroundGradient}" Padding="16,6">
                <StackPanel>
                  <TextBlock FontWeight="SemiBold" FontSize="13" Text="Row Counts" Margin="0,0,0,4" />
                  <ItemsControl ItemsSource="{Binding RowCountsDict}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Grid Margin="0,0,0,2">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="60" />
                          </Grid.ColumnDefinitions>
                          <TextBlock Grid.Column="0" Text="{Binding Key}" FontSize="11" />
                          <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="11" FontWeight="SemiBold"
                                     HorizontalAlignment="Right" />
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <TextBlock Text="{Binding ValidationSummary, StringFormat='Validation: {0}'}"
                             Margin="0,6,0,2" FontSize="11" />
                  <TextBlock Text="{Binding ErrorMessage, StringFormat='Error: {0}'}"
                             Foreground="#E81123" FontSize="11"
                             Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </DataGrid.RowDetailsTemplate>
        </DataGrid>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
