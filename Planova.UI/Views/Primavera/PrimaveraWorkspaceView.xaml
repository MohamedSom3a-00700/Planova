<UserControl x:Class="Planova.UI.Views.Primavera.PrimaveraWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels.Primavera"
             xmlns:views="clr-namespace:Planova.UI.Views.Primavera"
             xmlns:ui="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:PrimaveraWorkspaceViewModel}">
  <UserControl.Resources>
    <DataTemplate DataType="{x:Type vm:PrimaveraCalendarsViewModel}">
      <views:PrimaveraCalendarsView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:PrimaveraCodesViewModel}">
      <views:PrimaveraCodesView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:PrimaveraActivitiesViewModel}">
      <views:PrimaveraActivitiesView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:PrimaveraRelationshipsViewModel}">
      <views:PrimaveraRelationshipsView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:PrimaveraResourcesViewModel}">
      <views:PrimaveraResourcesView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:PrimaveraBaselinesViewModel}">
      <views:PrimaveraBaselinesView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:PrimaveraUdfsViewModel}">
      <views:PrimaveraUdfsView />
    </DataTemplate>
  </UserControl.Resources>
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="280" />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Grid.Column="0" Background="{DynamicResource ThemeCard}" Padding="12,10" Margin="12,12,8,0" CornerRadius="6"
            BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1">
      <StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
          <ui:SymbolIcon Symbol="Document24" FontSize="16" Margin="0,0,6,0"
                         Foreground="{DynamicResource ThemeForeground}" />
          <TextBlock Text="XER Session" FontWeight="SemiBold" FontSize="13" />
        </StackPanel>
        <ComboBox ItemsSource="{Binding ImportedSessions}"
                  SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                  Width="500" HorizontalAlignment="Left" FontSize="13">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding SourceFileName}" FontWeight="SemiBold" />
                <TextBlock Text="  [" FontSize="11" Foreground="Gray" />
                <TextBlock Text="{Binding ProjectCode}" FontSize="11" Foreground="Gray" />
                <TextBlock Text="] " FontSize="11" Foreground="Gray" />
                <TextBlock Text="{Binding ProjectName}" FontSize="11" Foreground="Gray" />
              </StackPanel>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
      </StackPanel>
    </Border>

    <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource ThemeCard}" Padding="10,8" Margin="12,8,8,0" CornerRadius="6"
            BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1">
      <StackPanel Orientation="Horizontal">
        <ui:Button Command="{Binding SaveChangesCommand}" Appearance="Primary"
                   Content="Save Changes" Width="120" Margin="0,0,8,0" />
        <ui:Button Command="{Binding OpenValidationCommand}"
                   Content="Validate" Width="90" Margin="0,0,8,0" />
        <Border Background="{DynamicResource BrandTextSecondary}" CornerRadius="4" Padding="8,4" Opacity="0.1"
                VerticalAlignment="Center">
          <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" FontSize="12"
                     Foreground="{DynamicResource ThemeForeground}" />
        </Border>
      </StackPanel>
    </Border>

    <Border Grid.Row="2" Grid.Column="0" BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1"
            Padding="0" Margin="12,8,8,12" CornerRadius="6" Background="{DynamicResource ThemeCard}">
      <TabControl SelectedIndex="{Binding SelectedTabIndex}"
                  Background="Transparent" BorderThickness="0">
        <TabControl.Resources>
          <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="10,6" />
          </Style>
        </TabControl.Resources>
        <TabItem Header="Calendars" Content="{Binding CalendarsViewModel}" />
        <TabItem Header="Codes" Content="{Binding CodesViewModel}" />
        <TabItem Header="Activities" Content="{Binding ActivitiesViewModel}" />
        <TabItem Header="Relationships" Content="{Binding RelationshipsViewModel}" />
        <TabItem Header="Resources" Content="{Binding ResourcesViewModel}" />
        <TabItem Header="Baselines" Content="{Binding BaselinesViewModel}" />
        <TabItem Header="UDFs" Content="{Binding UdfsViewModel}" />
      </TabControl>
    </Border>

    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" Grid.RowSpan="3" />

    <ScrollViewer Grid.Column="2" Grid.RowSpan="3" VerticalScrollBarVisibility="Auto" Margin="0,12,12,12">
      <StackPanel>
        <Border Background="{DynamicResource ThemeCard}" Padding="12" CornerRadius="6" Margin="0,0,0,8"
                BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1">
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
              <ui:SymbolIcon Symbol="DataPie24" FontSize="16" Margin="0,0,6,0"
                             Foreground="{DynamicResource ThemeForeground}" />
              <TextBlock Text="Entity Summary" FontSize="14" FontWeight="SemiBold" />
            </StackPanel>
            <ItemsControl ItemsSource="{Binding EntitySummaries}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource ThemeBorder}" Padding="4,3">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="50" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" Text="{Binding TypeName}" FontWeight="Medium" FontSize="12" />
                      <Border Grid.Column="1" Background="{DynamicResource ThemeBorder}" CornerRadius="8"
                              Padding="6,1" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding Count}" FontWeight="SemiBold" FontSize="11"
                                   HorizontalAlignment="Center" />
                      </Border>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <Border Background="{DynamicResource ThemeCard}" Padding="12" CornerRadius="6" Margin="0,0,0,8"
                BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1">
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
              <ui:SymbolIcon Symbol="DocumentTable24" FontSize="16" Margin="0,0,6,0"
                             Foreground="{DynamicResource ThemeForeground}" />
              <TextBlock Text="Export to Excel" FontSize="14" FontWeight="SemiBold" />
            </StackPanel>
            <TextBlock Text="Exports all entity types to a single sheet." FontSize="11" Margin="0,0,0,10"
                       Foreground="{DynamicResource BrandTextSecondary}" />
            <ui:Button Command="{Binding ExportToExcelCommand}" Content="Export to Excel" Width="150" />
          </StackPanel>
        </Border>

        <Border Background="{DynamicResource ThemeCard}" Padding="12" CornerRadius="6"
                BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1">
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
              <ui:SymbolIcon Symbol="Table24" FontSize="16" Margin="0,0,6,0"
                             Foreground="{DynamicResource ThemeForeground}" />
              <TextBlock Text="XER Table Sections" FontSize="14" FontWeight="SemiBold" />
            </StackPanel>
            <TextBlock Text="Select tables to export for editing." FontSize="11" Margin="0,0,0,8"
                       Foreground="{DynamicResource BrandTextSecondary}" />
            <ItemsControl ItemsSource="{Binding XeroTableSections}" MaxHeight="180">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                            Content="{Binding TableName}"
                            Margin="0,3" FontSize="12" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <ui:Button Command="{Binding ExportSelectedTablesCommand}"
                       Content="Export Selected Tables"
                       Width="170" Margin="0,8,0,0"
                       HorizontalAlignment="Left" />
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
