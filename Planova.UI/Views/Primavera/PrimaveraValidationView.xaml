<UserControl x:Class="Planova.UI.Views.Primavera.PrimaveraValidationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels.Primavera"
             xmlns:ui="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:PrimaveraValidationViewModel}">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="20,16,12,16">

        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
          <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="20" Margin="0,0,8,0"
                         Foreground="{DynamicResource ThemeForeground}" />
          <StackPanel>
            <TextBlock Text="Schedule Validation" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="Run integrity checks on imported schedule data" FontSize="12"
                       Foreground="{DynamicResource BrandTextSecondary}" />
          </StackPanel>
        </StackPanel>

        <Border Background="{DynamicResource ThemeCard}" Padding="12" CornerRadius="6" Margin="0,0,0,12"
                BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1">
          <StackPanel>
            <TextBlock Text="Select XER Session" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8" />
            <ComboBox ItemsSource="{Binding ImportedSessions}"
                      SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                      Width="450" HorizontalAlignment="Left">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding SourceFileName}" FontWeight="SemiBold" />
                    <TextBlock Text="  [" FontSize="11" Foreground="Gray" />
                    <TextBlock Text="{Binding ProjectCode}" FontSize="11" Foreground="Gray" />
                    <TextBlock Text="] " FontSize="11" Foreground="Gray" />
                    <TextBlock Text="{Binding ProjectName}" FontSize="11" Foreground="Gray" />
                  </StackPanel>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
          <ui:Button Command="{Binding RunValidationCommand}" Appearance="Primary"
                     Content="Run Validation" Width="140" Margin="0,0,8,0" />
          <ComboBox SelectedValue="{Binding SelectedSeverityFilter}" Width="130">
            <ComboBoxItem Content="All Issues" IsSelected="True" />
            <ComboBoxItem Content="Errors" />
            <ComboBoxItem Content="Warnings" />
            <ComboBoxItem Content="Info" />
          </ComboBox>
        </StackPanel>

        <Border Background="{DynamicResource ThemeCard}" Padding="8,6" CornerRadius="4" Margin="0,0,0,12"
                BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1">
          <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                     Foreground="{DynamicResource ThemeForeground}" />
        </Border>

        <ItemsControl ItemsSource="{Binding GroupedIssues}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Background="{DynamicResource ThemeCard}" Padding="12" CornerRadius="6" Margin="0,0,0,10"
                      BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1">
                <StackPanel>
                  <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <ui:SymbolIcon Symbol="List24" FontSize="16" Margin="0,0,6,0"
                                   Foreground="{DynamicResource ThemeForeground}" />
                    <TextBlock Text="{Binding Key}" FontWeight="Bold" FontSize="14" />
                  </StackPanel>
                  <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource ThemeBorder}" Padding="6,4">
                          <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Warning24" FontSize="14" Foreground="#FFB83B" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="12" />
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </ScrollViewer>

    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" />

    <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="12,16,20,16">
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
          <ui:SymbolIcon Symbol="DataBarVertical24" FontSize="20" Margin="0,0,8,0"
                         Foreground="{DynamicResource ThemeForeground}" />
          <StackPanel>
            <TextBlock Text="DCMA Assessment" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="14-Point Schedule Assessment" FontSize="12"
                       Foreground="{DynamicResource BrandTextSecondary}" />
          </StackPanel>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
          <ui:Button Command="{Binding RunDcmaAssessmentCommand}" Appearance="Primary"
                     Content="Run DCMA Assessment" Width="180" Margin="0,0,8,0" />
          <ui:Button Command="{Binding ReevaluateThresholdsCommand}"
                     Content="Recheck Thresholds" Width="140" />
        </StackPanel>

        <Border BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Padding="16" CornerRadius="6" Margin="0,0,0,12"
                Background="{DynamicResource ThemeCard}">
          <StackPanel Orientation="Horizontal">
            <ui:SymbolIcon Symbol="Star24" FontSize="24" Margin="0,0,10,0"
                           Foreground="{DynamicResource ThemeForeground}" />
            <TextBlock FontSize="20" FontWeight="Bold"
                       Text="{Binding OverallScore, StringFormat='Overall Score: {0:N1}%'}"
                       VerticalAlignment="Center" />
          </StackPanel>
        </Border>

        <Border BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" CornerRadius="6"
                Background="{DynamicResource ThemeCard}">
          <StackPanel>
            <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource ThemeBorder}" Padding="8,6">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="30" />
                  <ColumnDefinition Width="130" />
                  <ColumnDefinition Width="55" />
                  <ColumnDefinition Width="50" />
                  <ColumnDefinition Width="50" />
                  <ColumnDefinition Width="50" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="#" FontWeight="Bold" FontSize="11" Foreground="Gray" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="Point" FontWeight="Bold" FontSize="11" Foreground="Gray" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="%" FontWeight="Bold" FontSize="11" Foreground="Gray" VerticalAlignment="Center" HorizontalAlignment="Right" />
                <TextBlock Grid.Column="3" Text="Count" FontWeight="Bold" FontSize="11" Foreground="Gray" VerticalAlignment="Center" HorizontalAlignment="Right" />
                <TextBlock Grid.Column="4" Text="Min #" FontWeight="Bold" FontSize="11" Foreground="Gray" VerticalAlignment="Center" />
                <TextBlock Grid.Column="5" Text="Min %" FontWeight="Bold" FontSize="11" Foreground="Gray" VerticalAlignment="Center" />
                <TextBlock Grid.Column="6" Text="Status" FontWeight="Bold" FontSize="11" Foreground="Gray" VerticalAlignment="Center" HorizontalAlignment="Center" />
              </Grid>
            </Border>

            <ItemsControl ItemsSource="{Binding DcmaThresholds}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource ThemeBorder}" Padding="8,5">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30" />
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="55" />
                        <ColumnDefinition Width="50" />
                        <ColumnDefinition Width="50" />
                        <ColumnDefinition Width="50" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" Text="{Binding PointNumber}" FontWeight="Bold" VerticalAlignment="Center" FontSize="12" />
                      <TextBlock Grid.Column="1" Text="{Binding PointName}" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="12" />
                      <TextBlock Grid.Column="2" Text="{Binding Percentage, StringFormat={}{0:N1}%}"
                                 HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource BrandTextSecondary}" />
                      <TextBlock Grid.Column="3" Text="{Binding IssueCount}" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" />
                      <TextBox Grid.Column="4" Text="{Binding MinNumber, TargetNullValue=''}" Width="40" HorizontalAlignment="Left" FontSize="11" ToolTip="Min Number" />
                      <TextBox Grid.Column="5" Text="{Binding MinPercentage, TargetNullValue=''}" Width="40" HorizontalAlignment="Left" FontSize="11" ToolTip="Min Percentage" />
                      <TextBlock Grid.Column="6" Text="{Binding Status}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="12">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="Gray" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding Status}" Value="Pass">
                                <Setter Property="Foreground" Value="#28A745" />
                              </DataTrigger>
                              <DataTrigger Binding="{Binding Status}" Value="Fail">
                                <Setter Property="Foreground" Value="#E81123" />
                              </DataTrigger>
                              <DataTrigger Binding="{Binding Status}" Value="Warning">
                                <Setter Property="Foreground" Value="#FFB83B" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
