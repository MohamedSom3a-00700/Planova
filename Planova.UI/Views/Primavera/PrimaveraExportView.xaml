<UserControl x:Class="Planova.UI.Views.Primavera.PrimaveraExportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels.Primavera"
             xmlns:ui="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:PrimaveraExportViewModel}">
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
  </UserControl.Resources>
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="20,16">

      <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
        <ui:SymbolIcon Symbol="ArrowUpload24" FontSize="20" Margin="0,0,8,0"
                       Foreground="{DynamicResource ThemeForeground}" />
        <StackPanel>
          <TextBlock Text="Export to XER" FontSize="18" FontWeight="SemiBold" />
          <TextBlock Text="Export workspace data to a Primavera P6 XER file" FontSize="12"
                     Foreground="{DynamicResource BrandTextSecondary}" />
        </StackPanel>
      </StackPanel>

      <Border Background="{DynamicResource ThemeCard}" Padding="16" CornerRadius="6" Margin="0,0,0,16"
              BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1">
        <StackPanel>
          <TextBlock Text="Output Path" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8" />
          <StackPanel Orientation="Horizontal">
            <TextBox Text="{Binding OutputPath, Mode=TwoWay}"
                     Width="450" Margin="0,0,8,0" />
            <ui:Button Command="{Binding BrowseOutputPathCommand}"
                       Content="Browse" Width="90" />
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Background="{DynamicResource ThemeCard}" Padding="16" CornerRadius="6" Margin="0,0,0,16"
              BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1">
        <StackPanel>
          <TextBlock Text="Entity Selection" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,12" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
              <CheckBox IsChecked="{Binding IncludeCalendars}" Content="Calendars" Margin="0,0,0,8" FontSize="13" />
              <CheckBox IsChecked="{Binding IncludeCodes}" Content="Codes" Margin="0,0,0,8" FontSize="13" />
              <CheckBox IsChecked="{Binding IncludeActivities}" Content="Activities" Margin="0,0,0,8" FontSize="13" />
              <CheckBox IsChecked="{Binding IncludeRelationships}" Content="Relationships" FontSize="13" />
            </StackPanel>
            <StackPanel Grid.Column="1">
              <CheckBox IsChecked="{Binding IncludeResources}" Content="Resource Assignments" Margin="0,0,0,8" FontSize="13" />
              <CheckBox IsChecked="{Binding IncludeBaselines}" Content="Baselines" Margin="0,0,0,8" FontSize="13" />
              <CheckBox IsChecked="{Binding IncludeUdfs}" Content="UDFs" Margin="0,0,0,8" FontSize="13" />
              <CheckBox IsChecked="{Binding PreserveRawTables}" Content="Preserve Raw Tables" FontSize="13" />
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <ui:Button Command="{Binding ExportCommand}" Appearance="Primary"
                 Content="Export" Width="120" Margin="0,0,0,16" />

      <Border Background="{DynamicResource ThemeCard}" Padding="16" CornerRadius="6" Margin="0,0,0,8"
              BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1"
              Visibility="{Binding HasExportResult, Converter={StaticResource BoolToVis}}">
        <StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="18" Foreground="#28A745" Margin="0,0,8,0" />
            <TextBlock Text="Export Details" FontWeight="SemiBold" FontSize="15" />
          </StackPanel>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="100" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Status:" FontWeight="SemiBold" FontSize="12" />
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ExportStatus}" FontSize="12" />
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Entity Types:" FontWeight="SemiBold" FontSize="12" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ExportDetails}" FontSize="12" />
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Output:" FontWeight="SemiBold" FontSize="12" />
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding OutputPath}" TextWrapping="Wrap" FontSize="12" />
          </Grid>
        </StackPanel>
      </Border>

      <TextBlock Text="{Binding StatusMessage}" Margin="0,8,0,0" FontSize="12"
                 Foreground="{DynamicResource ThemeForeground}" />
    </StackPanel>
  </ScrollViewer>
</UserControl>
