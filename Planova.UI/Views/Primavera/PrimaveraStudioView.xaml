<UserControl x:Class="Planova.UI.Views.Primavera.PrimaveraStudioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels.Primavera"
             xmlns:shared="clr-namespace:Planova.UI.Views.Shared"
             xmlns:ui="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:PrimaveraStudioViewModel}"
             Background="{DynamicResource WorkspaceBackgroundGradient}"
             FontFamily="{DynamicResource BrandFontFamily}">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{DynamicResource ThemeCard}" Padding="16,12,16,8">
      <StackPanel>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <ui:SymbolIcon Symbol="CalendarClock24" FontSize="20" Margin="0,0,10,0"
                         Foreground="{DynamicResource ThemeForeground}" />
          <TextBlock Text="Primavera Studio" FontSize="22" FontWeight="SemiBold"
                     Foreground="{DynamicResource ThemeForeground}"/>
        </StackPanel>
        <TextBlock Text="Import, edit, validate, and export Primavera P6 XER schedule data"
                   FontSize="13" Foreground="{DynamicResource BrandTextSecondary}"
                   Margin="34,2,0,0" />
      </StackPanel>
    </Border>

    <TabControl Grid.Row="1" Margin="12,8,12,12"
                ItemsSource="{Binding Tabs}"
                SelectedItem="{Binding SelectedTab, Mode=TwoWay}"
                Background="Transparent"
                BorderThickness="0"
                FontFamily="{DynamicResource BrandFontFamily}">
      <TabControl.ItemTemplate>
        <DataTemplate>
          <TextBlock Text="{Binding Header}" FontWeight="Medium" FontSize="14" Padding="8,4"/>
        </DataTemplate>
      </TabControl.ItemTemplate>
      <TabControl.ContentTemplate>
        <DataTemplate>
          <Border Background="{DynamicResource ThemeCard}" CornerRadius="6" Padding="0"
                  BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1"
                  Margin="0,4,0,0">
            <ContentControl Content="{Binding Content}"
                            Focusable="False"
                            Background="Transparent"/>
          </Border>
        </DataTemplate>
      </TabControl.ContentTemplate>
    </TabControl>
  </Grid>
</UserControl>
