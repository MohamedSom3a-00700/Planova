<UserControl x:Class="Planova.UI.Views.Primavera.PrimaveraBaselinesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels.Primavera"
             xmlns:ui="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:PrimaveraBaselinesViewModel}">
  <Grid Margin="4">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <Border Background="#FFFFF5F0" BorderBrush="#FFDDC0" BorderThickness="1" Padding="10,8" CornerRadius="4" Margin="0,0,0,8">
      <StackPanel Orientation="Horizontal">
        <ui:SymbolIcon Symbol="Info24" FontSize="16" Foreground="#CC7000" Margin="0,0,8,0" VerticalAlignment="Center" />
        <TextBlock Text="Baseline data is read-only. Baselines represent frozen schedule snapshots."
                   FontStyle="Italic" Foreground="#996600" FontSize="12" VerticalAlignment="Center" />
      </StackPanel>
    </Border>
    <DataGrid Grid.Row="1"
              ItemsSource="{Binding Baselines}"
              AutoGenerateColumns="True"
              IsReadOnly="True"
              VirtualizingPanel.VirtualizationMode="Recycling"
              BorderBrush="{DynamicResource ThemeBorder}"
              BorderThickness="1"
              RowHeight="26"
              FontSize="12">
      <DataGrid.Resources>
        <Style TargetType="DataGridColumnHeader">
          <Setter Property="FontWeight" Value="SemiBold" />
          <Setter Property="Padding" Value="6,3" />
        </Style>
        <Style TargetType="DataGridCell">
          <Setter Property="Padding" Value="6,2" />
        </Style>
      </DataGrid.Resources>
    </DataGrid>
  </Grid>
</UserControl>
