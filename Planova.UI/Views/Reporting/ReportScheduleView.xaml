<UserControl x:Class="Planova.UI.Views.Reporting.ReportScheduleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels.Reporting"
             xmlns:conv="clr-namespace:Planova.UI.Converters"
             d:DataContext="{d:DesignInstance vm:ReportScheduleViewModel}"
             Background="{DynamicResource WorkspaceBackgroundGradient}"
             FontFamily="{DynamicResource BrandFontFamily}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Report Schedule" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource ThemeForeground}" Margin="0,0,0,8"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="New Schedule" Command="{Binding OpenNewFormCommand}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}"
                    Margin="0,0,8,0" FontFamily="{DynamicResource BrandFontFamily}"/>
            <Button Content="Edit" Command="{Binding OpenEditFormCommand}"
                    IsEnabled="{Binding SelectedSchedule, Converter={StaticResource BoolToVis}}"
                    Margin="0,0,8,0" FontFamily="{DynamicResource BrandFontFamily}"/>
            <Button Content="Toggle Active" Command="{Binding ToggleActiveCommand}"
                    IsEnabled="{Binding SelectedSchedule, Converter={StaticResource BoolToVis}}"
                    Margin="0,0,8,0" FontFamily="{DynamicResource BrandFontFamily}"/>
            <Button Content="Delete" Command="{Binding DeleteScheduleCommand}"
                    IsEnabled="{Binding SelectedSchedule, Converter={StaticResource BoolToVis}}"
                    FontFamily="{DynamicResource BrandFontFamily}"/>
        </StackPanel>

        <!-- Error notification -->
        <Border Grid.Row="2" Background="#FFF0E0" BorderBrush="#FFD080" BorderThickness="1" Padding="8"
                Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#CC6600"/>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Schedule List (with empty state overlay) -->
            <Grid Grid.Column="0" Margin="0,0,8,0"
                  Visibility="{Binding IsFormOpen, Converter={StaticResource InverseBool}}">
                <!-- Empty state -->
                <Border Visibility="{Binding HasNoSchedules, Converter={StaticResource BoolToVis}}"
                        Background="{DynamicResource ThemeBackgroundMedium}"
                        BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1"
                        Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="No Schedules" FontSize="20" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ThemeForeground}"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="Click 'New Schedule' to configure automatic report generation."
                                   FontSize="14" Foreground="{DynamicResource ThemeForeground}"
                                   HorizontalAlignment="Center" TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Schedule DataGrid -->
                <Border Background="{DynamicResource ThemeBackgroundMedium}"
                        BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Padding="8"
                        Visibility="{Binding HasNoSchedules, Converter={StaticResource InverseBool}}">
                    <DataGrid ItemsSource="{Binding Schedules}"
                          SelectedItem="{Binding SelectedSchedule, Mode=TwoWay}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          Background="Transparent" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Type" Binding="{Binding ReportType}" Width="80"/>
                        <DataGridTextColumn Header="Frequency" Binding="{Binding Frequency}" Width="80"/>
                        <DataGridTextColumn Header="Time" Binding="{Binding TimeOfDay}" Width="70"/>
                        <DataGridTextColumn Header="Active" Binding="{Binding IsActive}" Width="60"/>
                        <DataGridTextColumn Header="Next Run" Binding="{Binding NextRunAt, StringFormat={}{0:g}}" Width="140"/>
                        <DataGridTextColumn Header="Last Run" Binding="{Binding LastRunAt, StringFormat={}{0:g}}" Width="140"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding LastStatus}" Width="80"/>
                        <DataGridTextColumn Header="Format" Binding="{Binding ExportFormats}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
                    </Border>
                </Grid>

            <!-- Form Panel -->
            <Border Grid.Column="0" Background="{DynamicResource ThemeBackgroundMedium}"
                    BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Padding="12"
                    Margin="0,0,8,0"
                    Visibility="{Binding IsFormOpen, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="{Binding IsEditing, Converter={StaticResource BoolToVis}, StringFormat=Edit Schedule|New Schedule}"
                               FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <TextBlock Text="Report Type" FontSize="12" Foreground="{DynamicResource ThemeForeground}"/>
                    <ComboBox ItemsSource="{x:Static vm:ReportScheduleViewModel.ReportTypes}"
                              SelectedItem="{Binding FormReportType, Mode=TwoWay}"
                              Margin="0,2,0,8" FontFamily="{DynamicResource BrandFontFamily}"/>

                    <TextBlock Text="Frequency" FontSize="12" Foreground="{DynamicResource ThemeForeground}"/>
                    <ComboBox ItemsSource="{x:Static vm:ReportScheduleViewModel.Frequencies}"
                              SelectedItem="{Binding FormFrequency, Mode=TwoWay}"
                              Margin="0,2,0,8" FontFamily="{DynamicResource BrandFontFamily}"/>

                    <TextBlock Text="Time of Day (HH:mm)" FontSize="12" Foreground="{DynamicResource ThemeForeground}"/>
                    <TextBox Text="{Binding FormTimeOfDay, Mode=TwoWay}"
                             Margin="0,2,0,8" FontFamily="{DynamicResource BrandFontFamily}"/>

                    <TextBlock Text="Time Zone" FontSize="12" Foreground="{DynamicResource ThemeForeground}"/>
                    <ComboBox ItemsSource="{x:Static vm:ReportScheduleViewModel.TimeZones}"
                              SelectedItem="{Binding FormTimeZoneId, Mode=TwoWay}"
                              Margin="0,2,0,8" FontFamily="{DynamicResource BrandFontFamily}"/>

                    <TextBlock Text="Export Format" FontSize="12" Foreground="{DynamicResource ThemeForeground}"/>
                    <TextBox Text="{Binding FormExportFormats, Mode=TwoWay}"
                             Margin="0,2,0,8" FontFamily="{DynamicResource BrandFontFamily}"/>

                    <TextBlock Text="Max Retries" FontSize="12" Foreground="{DynamicResource ThemeForeground}"/>
                    <TextBox Text="{Binding FormMaxRetries, Mode=TwoWay}"
                             Margin="0,2,0,8" FontFamily="{DynamicResource BrandFontFamily}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Save" Command="{Binding SaveScheduleCommand}"
                                Margin="0,0,8,0" FontFamily="{DynamicResource BrandFontFamily}"/>
                        <Button Content="Cancel" Command="{Binding CloseFormCommand}"
                                FontFamily="{DynamicResource BrandFontFamily}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Loading Overlay -->
            <Border Grid.Column="0" Grid.ColumnSpan="2"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                    Background="#40FFFFFF">
                <TextBlock Text="Loading..." FontSize="16" FontWeight="SemiBold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource ThemeForeground}"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
