<UserControl x:Class="Planova.UI.Views.Reporting.DailyReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels.Reporting"
             xmlns:conv="clr-namespace:Planova.UI.Converters"
             d:DataContext="{d:DesignInstance vm:DailyReportViewModel}"
             Background="{DynamicResource WorkspaceBackgroundGradient}"
             FontFamily="{DynamicResource BrandFontFamily}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Daily Report" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource ThemeForeground}" Margin="0,0,0,8"/>

        <!-- Toolbar: Date picker + Generate + Export buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <DatePicker SelectedDate="{Binding SelectedDate, Mode=TwoWay}"
                        Width="180" Margin="0,0,8,0"
                        FontFamily="{DynamicResource BrandFontFamily}"/>
            <Button Content="Generate" Command="{Binding GenerateReportCommand}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}"
                    Margin="0,0,8,0"
                    FontFamily="{DynamicResource BrandFontFamily}"/>
            <Button Command="{Binding GenerateAiNarrativeCommand}"
                    IsEnabled="{Binding HasData}"
                    Margin="0,0,8,0"
                    FontFamily="{DynamicResource BrandFontFamily}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚡" FontSize="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="AI Narrative" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Content="Excel" Command="{Binding ExportToExcelCommand}"
                    IsEnabled="{Binding HasData}"
                    Margin="0,0,8,0"
                    FontFamily="{DynamicResource BrandFontFamily}"/>
            <Button Content="PDF" Command="{Binding ExportToPdfCommand}"
                    IsEnabled="{Binding HasData}"
                    Margin="0,0,8,0"
                    FontFamily="{DynamicResource BrandFontFamily}"/>
            <Button Content="Word" Command="{Binding ExportToWordCommand}"
                    IsEnabled="{Binding HasData}"
                    FontFamily="{DynamicResource BrandFontFamily}"/>
            <Separator Margin="8,0" Width="1" Background="{DynamicResource ThemeBorder}"/>
            <ComboBox ItemsSource="{x:Static vm:DailyReportViewModel.StatusOptions}"
                      SelectedItem="{Binding CurrentInstanceStatus, Mode=TwoWay}"
                      IsEnabled="{Binding HasCurrentInstance}"
                      Width="90" Margin="0,0,4,0"
                      FontFamily="{DynamicResource BrandFontFamily}"/>
            <Button Content="Apply Status" Command="{Binding ChangeStatusCommand}"
                    IsEnabled="{Binding HasCurrentInstance}"
                    FontFamily="{DynamicResource BrandFontFamily}"/>
        </StackPanel>

        <!-- Error notification -->
        <Border Grid.Row="2" Background="#FFF0E0" BorderBrush="#FFD080" BorderThickness="1" Padding="8"
                Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#CC6600"/>
        </Border>

        <!-- Loading overlay -->
        <Border Grid.Row="3" Grid.RowSpan="2"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                Background="#40FFFFFF">
            <TextBlock Text="Loading..." FontSize="16" FontWeight="SemiBold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{DynamicResource ThemeForeground}"/>
        </Border>

        <!-- Empty state -->
        <Border Grid.Row="3" Grid.RowSpan="2"
                Visibility="{Binding HasNoData, Converter={StaticResource BoolToVis}}"
                Background="{DynamicResource ThemeBackgroundMedium}"
                BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1"
                Margin="40" Padding="24"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Daily Report" FontSize="20" FontWeight="SemiBold"
                           Foreground="{DynamicResource ThemeForeground}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="Select a date above and click Generate to create a Daily Report."
                           FontSize="14" Foreground="{DynamicResource ThemeForeground}"
                           HorizontalAlignment="Center" TextWrapping="Wrap"
                           TextAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Content sections -->
        <ScrollViewer Grid.Row="4"
                      Visibility="{Binding HasData, Converter={StaticResource BoolToVis}}"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,12">
                <!-- Summary cards -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{DynamicResource ThemeBackgroundMedium}"
                            BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Padding="12" Margin="0,0,4,0">
                        <StackPanel>
                            <TextBlock Text="{Binding ReportData.TotalActivities}" FontSize="28" FontWeight="Bold"/>
                            <TextBlock Text="Total Activities" FontSize="12" Foreground="{DynamicResource ThemeForeground}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="{DynamicResource ThemeBackgroundMedium}"
                            BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Padding="12" Margin="4,0">
                        <StackPanel>
                            <TextBlock Text="{Binding ReportData.CompletedActivities}" FontSize="28" FontWeight="Bold" Foreground="#28A745"/>
                            <TextBlock Text="Completed" FontSize="12" Foreground="{DynamicResource ThemeForeground}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="{DynamicResource ThemeBackgroundMedium}"
                            BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Padding="12" Margin="4,0">
                        <StackPanel>
                            <TextBlock Text="{Binding ReportData.InProgressActivities}" FontSize="28" FontWeight="Bold" Foreground="#007BFF"/>
                            <TextBlock Text="In Progress" FontSize="12" Foreground="{DynamicResource ThemeForeground}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Background="{DynamicResource ThemeBackgroundMedium}"
                            BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Padding="12" Margin="4,0,0,0">
                        <StackPanel>
                            <TextBlock Text="{Binding ReportData.NotStartedActivities}" FontSize="28" FontWeight="Bold" Foreground="#DC3545"/>
                            <TextBlock Text="Not Started" FontSize="12" Foreground="{DynamicResource ThemeForeground}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Overall Progress -->
                <Border Background="{DynamicResource ThemeBackgroundMedium}"
                        BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Overall Progress" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding ReportData.OverallPercentComplete, StringFormat={}{0:P1}}" FontSize="36" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Progress Today -->
                <Border Background="{DynamicResource ThemeBackgroundMedium}"
                        BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Progress Today" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <DataGrid ItemsSource="{Binding ReportData.ProgressToday}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="Transparent" BorderThickness="0"
                                  MaxHeight="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Code" Binding="{Binding ActivityCode}" Width="80"/>
                                <DataGridTextColumn Header="Activity" Binding="{Binding ActivityName}" Width="*"/>
                                <DataGridTextColumn Header="% Complete" Binding="{Binding PercentComplete, StringFormat={}{0:P0}}" Width="100"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Workforce -->
                <Border Background="{DynamicResource ThemeBackgroundMedium}"
                        BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Workforce" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <DataGrid ItemsSource="{Binding ReportData.Workforce}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="Transparent" BorderThickness="0"
                                  MaxHeight="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Resource" Binding="{Binding ResourceName}" Width="*"/>
                                <DataGridTextColumn Header="Activity" Binding="{Binding ActivityName}" Width="*"/>
                                <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="80"/>
                                <DataGridTextColumn Header="UOM" Binding="{Binding UnitOfMeasure}" Width="60"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Equipment -->
                <Border Background="{DynamicResource ThemeBackgroundMedium}"
                        BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Equipment" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <DataGrid ItemsSource="{Binding ReportData.Equipment}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="Transparent" BorderThickness="0"
                                  MaxHeight="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Equipment" Binding="{Binding EquipmentName}" Width="*"/>
                                <DataGridTextColumn Header="Activity" Binding="{Binding ActivityName}" Width="*"/>
                                <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="80"/>
                                <DataGridTextColumn Header="UOM" Binding="{Binding UnitOfMeasure}" Width="60"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- AI Narrative -->
                <Border Background="{DynamicResource ThemeBackgroundMedium}"
                        BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Padding="12"
                        Visibility="{Binding HasAiNarrative, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="AI Narrative" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding AiNarrative}" TextWrapping="Wrap"
                                   FontSize="13" Foreground="{DynamicResource ThemeForeground}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
