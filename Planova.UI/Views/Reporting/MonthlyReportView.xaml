<UserControl x:Class="Planova.UI.Views.Reporting.MonthlyReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels.Reporting"
             xmlns:conv="clr-namespace:Planova.UI.Converters"
             d:DataContext="{d:DesignInstance vm:MonthlyReportViewModel}"
             Background="{DynamicResource WorkspaceBackgroundGradient}"
             FontFamily="{DynamicResource BrandFontFamily}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Monthly Report" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource ThemeForeground}" Margin="0,0,0,8"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <DatePicker SelectedDate="{Binding SelectedMonth, Mode=TwoWay}"
                        Width="180" Margin="0,0,8,0"
                        FontFamily="{DynamicResource BrandFontFamily}"/>
            <Button Content="Generate" Command="{Binding GenerateReportCommand}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}"
                    Margin="0,0,8,0" FontFamily="{DynamicResource BrandFontFamily}"/>
            <Button Command="{Binding GenerateAiNarrativeCommand}"
                    IsEnabled="{Binding HasData}" Margin="0,0,8,0"
                    FontFamily="{DynamicResource BrandFontFamily}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚡" FontSize="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="AI Narrative" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Content="Excel" Command="{Binding ExportToExcelCommand}"
                    IsEnabled="{Binding HasData}" Margin="0,0,8,0"
                    FontFamily="{DynamicResource BrandFontFamily}"/>
            <Button Content="PDF" Command="{Binding ExportToPdfCommand}"
                    IsEnabled="{Binding HasData}" Margin="0,0,8,0"
                    FontFamily="{DynamicResource BrandFontFamily}"/>
            <Button Content="Word" Command="{Binding ExportToWordCommand}"
                    IsEnabled="{Binding HasData}"
                    FontFamily="{DynamicResource BrandFontFamily}"/>
            <Separator Margin="8,0" Width="1" Background="{DynamicResource ThemeBorder}"/>
            <ComboBox ItemsSource="{x:Static vm:MonthlyReportViewModel.StatusOptions}"
                      SelectedItem="{Binding CurrentInstanceStatus, Mode=TwoWay}"
                      IsEnabled="{Binding HasCurrentInstance}"
                      Width="90" Margin="0,0,4,0"
                      FontFamily="{DynamicResource BrandFontFamily}"/>
            <Button Content="Apply Status" Command="{Binding ChangeStatusCommand}"
                    IsEnabled="{Binding HasCurrentInstance}"
                    FontFamily="{DynamicResource BrandFontFamily}"/>
        </StackPanel>

        <!-- Error notification -->
        <Border Grid.Row="2" Background="#FFF0E0" BorderBrush="#FFD080" BorderThickness="1" Padding="8"
                Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#CC6600"/>
        </Border>

        <Border Grid.Row="3" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                Background="#40FFFFFF">
            <TextBlock Text="Loading..." FontSize="16" FontWeight="SemiBold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{DynamicResource ThemeForeground}"/>
        </Border>

        <!-- Empty state -->
        <Border Grid.Row="3"
                Visibility="{Binding HasNoData, Converter={StaticResource BoolToVis}}"
                Background="{DynamicResource ThemeBackgroundMedium}"
                BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1"
                Margin="40" Padding="24"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Monthly Report" FontSize="20" FontWeight="SemiBold"
                           Foreground="{DynamicResource ThemeForeground}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="Select a month above and click Generate to create a Monthly Report."
                           FontSize="14" Foreground="{DynamicResource ThemeForeground}"
                           HorizontalAlignment="Center" TextWrapping="Wrap"
                           TextAlignment="Center"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="3" Visibility="{Binding HasData, Converter={StaticResource BoolToVis}}"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,12">
                <!-- EVM Summary Cards -->
                <Border Background="{DynamicResource ThemeBackgroundMedium}"
                        BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Padding="12"
                        Margin="0,0,0,12"
                        Visibility="{Binding ReportData.EvmSummary, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="EVM Summary" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Planned Value" FontSize="11" Foreground="{DynamicResource ThemeForeground}"/>
                                <TextBlock Text="{Binding ReportData.EvmSummary.PlannedValue, StringFormat={}{0:N2}}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4,0">
                                <TextBlock Text="Earned Value" FontSize="11" Foreground="{DynamicResource ThemeForeground}"/>
                                <TextBlock Text="{Binding ReportData.EvmSummary.EarnedValue, StringFormat={}{0:N2}}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="4,0,0,0">
                                <TextBlock Text="Actual Cost" FontSize="11" Foreground="{DynamicResource ThemeForeground}"/>
                                <TextBlock Text="{Binding ReportData.EvmSummary.ActualCost, StringFormat={}{0:N2}}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="CPI" FontSize="11" Foreground="{DynamicResource ThemeForeground}"/>
                                <TextBlock Text="{Binding ReportData.EvmSummary.CostPerformanceIndex, StringFormat={}{0:N2}}" FontSize="16" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4,0">
                                <TextBlock Text="SPI" FontSize="11" Foreground="{DynamicResource ThemeForeground}"/>
                                <TextBlock Text="{Binding ReportData.EvmSummary.SchedulePerformanceIndex, StringFormat={}{0:N2}}" FontSize="16" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="4,0,0,0">
                                <TextBlock Text="EAC" FontSize="11" Foreground="{DynamicResource ThemeForeground}"/>
                                <TextBlock Text="{Binding ReportData.EvmSummary.EstimateAtCompletion, StringFormat={}{0:N2}}" FontSize="16" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Budget vs Actual -->
                <Border Background="{DynamicResource ThemeBackgroundMedium}"
                        BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Budget vs Actual" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <DataGrid ItemsSource="{Binding ReportData.BudgetVsActual}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="Transparent" BorderThickness="0" MaxHeight="150">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="*"/>
                                <DataGridTextColumn Header="Budget" Binding="{Binding Budget, StringFormat={}{0:N2}}" Width="120"/>
                                <DataGridTextColumn Header="Actual" Binding="{Binding Actual, StringFormat={}{0:N2}}" Width="120"/>
                                <DataGridTextColumn Header="Variance" Binding="{Binding Variance, StringFormat={}{0:N2}}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Progress by WBS -->
                <Border Background="{DynamicResource ThemeBackgroundMedium}"
                        BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Progress by WBS" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <DataGrid ItemsSource="{Binding ReportData.ProgressByWbs}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="Transparent" BorderThickness="0" MaxHeight="250">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Code" Binding="{Binding WbsCode}" Width="100"/>
                                <DataGridTextColumn Header="Name" Binding="{Binding WbsName}" Width="*"/>
                                <DataGridTextColumn Header="% Complete" Binding="{Binding PercentComplete, StringFormat={}{0:P1}}" Width="100"/>
                                <DataGridTextColumn Header="Weight" Binding="{Binding Weight, StringFormat={}{0:P1}}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Resource Productivity -->
                <Border Background="{DynamicResource ThemeBackgroundMedium}"
                        BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Resource Productivity" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <DataGrid ItemsSource="{Binding ReportData.ResourceProductivity}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="Transparent" BorderThickness="0" MaxHeight="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Resource" Binding="{Binding ResourceName}" Width="*"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding ResourceType}" Width="80"/>
                                <DataGridTextColumn Header="Total Qty" Binding="{Binding TotalQuantity}" Width="100"/>
                                <DataGridTextColumn Header="Total Cost" Binding="{Binding TotalCost, StringFormat={}{0:N2}}" Width="120"/>
                                <DataGridTextColumn Header="UOM" Binding="{Binding UnitOfMeasure}" Width="60"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- AI Narrative -->
                <Border Background="{DynamicResource ThemeBackgroundMedium}"
                        BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Padding="12"
                        Visibility="{Binding HasAiNarrative, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="AI Narrative" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding AiNarrative}" TextWrapping="Wrap"
                                   FontSize="13" Foreground="{DynamicResource ThemeForeground}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
