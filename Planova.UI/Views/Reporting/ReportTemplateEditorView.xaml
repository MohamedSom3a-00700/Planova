<UserControl x:Class="Planova.UI.Views.Reporting.ReportTemplateEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels.Reporting"
             xmlns:conv="clr-namespace:Planova.UI.Converters"
             d:DataContext="{d:DesignInstance vm:ReportTemplateEditorViewModel}"
             Background="{DynamicResource WorkspaceBackgroundGradient}"
             FontFamily="{DynamicResource BrandFontFamily}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Templates &amp; Settings" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource ThemeForeground}" Margin="0,0,0,8"/>

        <Border Grid.Row="2" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                Background="#40FFFFFF">
            <TextBlock Text="Loading..." FontSize="16" FontWeight="SemiBold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{DynamicResource ThemeForeground}"/>
        </Border>

        <TabControl Grid.Row="2" Visibility="{Binding IsLoading, Converter={StaticResource InverseBool}}"
                    Background="Transparent" BorderThickness="0">
            <TabItem Header="Section Visibility" FontFamily="{DynamicResource BrandFontFamily}">
                <StackPanel Margin="8">
                    <TextBlock Text="Report Type:" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{x:Static vm:ReportTemplateEditorViewModel.ReportTypes}"
                              SelectedItem="{Binding SelectedReportType, Mode=TwoWay}"
                              Width="140" Margin="0,0,0,8" FontFamily="{DynamicResource BrandFontFamily}"/>
                    <Button Content="Load Sections" Command="{Binding LoadSettingsCommand}"
                            Margin="0,0,0,8" FontFamily="{DynamicResource BrandFontFamily}"/>

                    <ItemsControl ItemsSource="{Binding Sections}" MaxHeight="300">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                          Content="{Binding Name}"
                                          Margin="0,2" FontFamily="{DynamicResource BrandFontFamily}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="Save Visibility" Command="{Binding SaveSectionVisibilityCommand}"
                            Margin="0,8,0,0" FontFamily="{DynamicResource BrandFontFamily}"/>

                    <Border Background="#FFF0E0" BorderBrush="#FFD080" BorderThickness="1" Padding="8" Margin="0,4,0,0"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#CC6600"/>
                    </Border>
                </StackPanel>
            </TabItem>

            <TabItem Header="Categories" FontFamily="{DynamicResource BrandFontFamily}">
                <StackPanel Margin="8">
                    <TextBlock Text="Template Category:" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="Select a category to filter which templates apply to this report type." 
                               FontSize="12" Foreground="{DynamicResource ThemeForeground}" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{x:Static vm:ReportTemplateEditorViewModel.TemplateCategories}"
                              SelectedItem="{Binding SelectedTemplateCategory, Mode=TwoWay}"
                              Width="180" Margin="0,0,0,8" FontFamily="{DynamicResource BrandFontFamily}"/>
                    <TextBlock Text="Categories help organize templates by project type (Construction, Engineering, Infrastructure, etc.)."
                               FontSize="11" Foreground="{DynamicResource ThemeForeground}" TextWrapping="Wrap"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="Project Parties" FontFamily="{DynamicResource BrandFontFamily}">
                <StackPanel Margin="8">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Load Parties" Command="{Binding LoadPartiesCommand}"
                                MinWidth="100" FontFamily="{DynamicResource BrandFontFamily}"/>
                        <Button Content="Load from Project" Command="{Binding LoadFromProjectCommand}"
                                Margin="8,0,0,0" MinWidth="120" FontFamily="{DynamicResource BrandFontFamily}"/>
                    </StackPanel>

                    <DataGrid ItemsSource="{Binding Parties}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              Background="Transparent" BorderThickness="0" MaxHeight="200">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Padding="8" Margin="0,8,0,0">
                        <StackPanel>
                            <TextBlock Text="Add Party" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock Text="Name" FontSize="12" Foreground="{DynamicResource ThemeForeground}"/>
                            <TextBox Text="{Binding NewPartyName, Mode=TwoWay}"
                                     Margin="0,2,0,4" FontFamily="{DynamicResource BrandFontFamily}"/>
                            <TextBlock Text="Role" FontSize="12" Foreground="{DynamicResource ThemeForeground}"/>
                            <ComboBox ItemsSource="{x:Static vm:ReportTemplateEditorViewModel.PartyRoles}"
                                      SelectedItem="{Binding NewPartyRole, Mode=TwoWay}"
                                      Margin="0,2,0,8" FontFamily="{DynamicResource BrandFontFamily}"/>
                            <Button Content="Add Party" Command="{Binding AddPartyCommand}"
                                    FontFamily="{DynamicResource BrandFontFamily}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#FFF0E0" BorderBrush="#FFD080" BorderThickness="1" Padding="8" Margin="0,4,0,0"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#CC6600"/>
                    </Border>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
