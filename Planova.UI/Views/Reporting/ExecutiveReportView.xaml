<UserControl x:Class="Planova.UI.Views.Reporting.ExecutiveReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels.Reporting"
             xmlns:conv="clr-namespace:Planova.UI.Converters"
             d:DataContext="{d:DesignInstance vm:ExecutiveReportViewModel}"
             Background="{DynamicResource WorkspaceBackgroundGradient}"
             FontFamily="{DynamicResource BrandFontFamily}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Executive Report" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource ThemeForeground}" Margin="0,0,0,8"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,4,0"
                       Foreground="{DynamicResource ThemeForeground}"/>
            <DatePicker SelectedDate="{Binding PeriodStart, Mode=TwoWay}"
                        Width="160" Margin="0,0,8,0"
                        FontFamily="{DynamicResource BrandFontFamily}"/>
            <TextBlock Text="To:" VerticalAlignment="Center" Margin="0,0,4,0"
                       Foreground="{DynamicResource ThemeForeground}"/>
            <DatePicker SelectedDate="{Binding PeriodEnd, Mode=TwoWay}"
                        Width="160" Margin="0,0,8,0"
                        FontFamily="{DynamicResource BrandFontFamily}"/>
            <Button Content="Generate" Command="{Binding GenerateReportCommand}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}"
                    Margin="0,0,8,0" FontFamily="{DynamicResource BrandFontFamily}"/>
            <Button Command="{Binding GenerateAiNarrativeCommand}"
                    IsEnabled="{Binding HasData}" Margin="0,0,8,0"
                    FontFamily="{DynamicResource BrandFontFamily}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚡" FontSize="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="AI Narrative" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Content="Excel" Command="{Binding ExportToExcelCommand}"
                    IsEnabled="{Binding HasData}" Margin="0,0,8,0"
                    FontFamily="{DynamicResource BrandFontFamily}"/>
            <Button Content="PDF" Command="{Binding ExportToPdfCommand}"
                    IsEnabled="{Binding HasData}" Margin="0,0,8,0"
                    FontFamily="{DynamicResource BrandFontFamily}"/>
            <Button Content="Word" Command="{Binding ExportToWordCommand}"
                    IsEnabled="{Binding HasData}"
                    FontFamily="{DynamicResource BrandFontFamily}"/>
            <Separator Margin="8,0" Width="1" Background="{DynamicResource ThemeBorder}"/>
            <ComboBox ItemsSource="{x:Static vm:ExecutiveReportViewModel.StatusOptions}"
                      SelectedItem="{Binding CurrentInstanceStatus, Mode=TwoWay}"
                      IsEnabled="{Binding HasCurrentInstance}"
                      Width="90" Margin="0,0,4,0"
                      FontFamily="{DynamicResource BrandFontFamily}"/>
            <Button Content="Apply Status" Command="{Binding ChangeStatusCommand}"
                    IsEnabled="{Binding HasCurrentInstance}"
                    FontFamily="{DynamicResource BrandFontFamily}"/>
        </StackPanel>

        <!-- Error notification -->
        <Border Grid.Row="2" Background="#FFF0E0" BorderBrush="#FFD080" BorderThickness="1" Padding="8"
                Visibility="{Binding ErrorMessage, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#CC6600"/>
        </Border>

        <Border Grid.Row="3" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                Background="#40FFFFFF">
            <TextBlock Text="Loading..." FontSize="16" FontWeight="SemiBold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{DynamicResource ThemeForeground}"/>
        </Border>

        <!-- Empty state -->
        <Border Grid.Row="3"
                Visibility="{Binding HasNoData, Converter={StaticResource BoolToVis}}"
                Background="{DynamicResource ThemeBackgroundMedium}"
                BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1"
                Margin="40" Padding="24"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Executive Report" FontSize="20" FontWeight="SemiBold"
                           Foreground="{DynamicResource ThemeForeground}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="Select a date range above and click Generate to create an Executive Report."
                           FontSize="14" Foreground="{DynamicResource ThemeForeground}"
                           HorizontalAlignment="Center" TextWrapping="Wrap"
                           TextAlignment="Center"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="3" Visibility="{Binding HasData, Converter={StaticResource BoolToVis}}"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,12">
                <!-- KPI Dashboard Cards -->
                <Border Background="{DynamicResource ThemeBackgroundMedium}"
                        BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Padding="12"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="KPI Dashboard" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding ReportData.KpiCards}" MaxHeight="200">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource ThemeBorder}"
                                            BorderThickness="1" Padding="8" Margin="4" Width="140">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Label}" FontSize="11"
                                                       Foreground="{DynamicResource ThemeForeground}"/>
                                            <TextBlock FontSize="20" FontWeight="Bold">
                                                <Run Text="{Binding Value, StringFormat={}{0:N2}}"/>
                                                <Run Text="{Binding Unit}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Trend}" FontSize="11"
                                                       Foreground="{DynamicResource ThemeForeground}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- S-Curve Data -->
                <Border Background="{DynamicResource ThemeBackgroundMedium}"
                        BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Padding="12"
                        Margin="0,0,0,12"
                        Visibility="{Binding ReportData.SCurve.Count, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="S-Curve" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <DataGrid ItemsSource="{Binding ReportData.SCurve}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="Transparent" BorderThickness="0" MaxHeight="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat={}{0:yyyy-MM}}" Width="100"/>
                                <DataGridTextColumn Header="Planned Value" Binding="{Binding PlannedValue, StringFormat={}{0:N2}}" Width="*"/>
                                <DataGridTextColumn Header="Earned Value" Binding="{Binding EarnedValue, StringFormat={}{0:N2}}" Width="*"/>
                                <DataGridTextColumn Header="Actual Cost" Binding="{Binding ActualCost, StringFormat={}{0:N2}}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Financial Overview -->
                <Border Background="{DynamicResource ThemeBackgroundMedium}"
                        BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Padding="12"
                        Margin="0,0,0,12"
                        Visibility="{Binding ReportData.FinancialOverview, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="Financial Overview" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Total Budget" FontSize="11" Foreground="{DynamicResource ThemeForeground}"/>
                                <TextBlock Text="{Binding ReportData.FinancialOverview.TotalBudget, StringFormat={}{0:N2}}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4,0">
                                <TextBlock Text="Total Actual Cost" FontSize="11" Foreground="{DynamicResource ThemeForeground}"/>
                                <TextBlock Text="{Binding ReportData.FinancialOverview.TotalActualCost, StringFormat={}{0:N2}}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="4,0,0,0">
                                <TextBlock Text="Variance" FontSize="11" Foreground="{DynamicResource ThemeForeground}"/>
                                <TextBlock Text="{Binding ReportData.FinancialOverview.TotalVariance, StringFormat={}{0:N2}}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Estimate at Completion" FontSize="11" Foreground="{DynamicResource ThemeForeground}"/>
                                <TextBlock Text="{Binding ReportData.FinancialOverview.EstimateAtCompletion, StringFormat={}{0:N2}}" FontSize="16" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4,0">
                                <TextBlock Text="Variance at Completion" FontSize="11" Foreground="{DynamicResource ThemeForeground}"/>
                                <TextBlock Text="{Binding ReportData.FinancialOverview.VarianceAtCompletion, StringFormat={}{0:N2}}" FontSize="16" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="4,0,0,0">
                                <TextBlock Text="CPI" FontSize="11" Foreground="{DynamicResource ThemeForeground}"/>
                                <TextBlock Text="{Binding ReportData.FinancialOverview.CostPerformanceIndex, StringFormat={}{0:N2}}" FontSize="16" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Milestones -->
                <Border Background="{DynamicResource ThemeBackgroundMedium}"
                        BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Padding="12"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Milestone Status" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <DataGrid ItemsSource="{Binding ReportData.Milestones}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="Transparent" BorderThickness="0" MaxHeight="250">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Activity" Binding="{Binding ActivityName}" Width="*"/>
                                <DataGridTextColumn Header="Code" Binding="{Binding ActivityCode}" Width="80"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                                <DataGridTextColumn Header="Planned Start" Binding="{Binding PlannedStart, StringFormat={}{0:yyyy-MM-dd}}" Width="100"/>
                                <DataGridTextColumn Header="Planned Finish" Binding="{Binding PlannedFinish, StringFormat={}{0:yyyy-MM-dd}}" Width="100"/>
                                <DataGridTextColumn Header="% Complete" Binding="{Binding PercentComplete, StringFormat={}{0:P1}}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Project Parties -->
                <Border Background="{DynamicResource ThemeBackgroundMedium}"
                        BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Padding="12"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Project Directory" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <DataGrid ItemsSource="{Binding ReportData.ProjectParties}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="Transparent" BorderThickness="0" MaxHeight="150">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Party Name" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- AI Narrative -->
                <Border Background="{DynamicResource ThemeBackgroundMedium}"
                        BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" Padding="12"
                        Visibility="{Binding HasAiNarrative, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="AI Executive Summary" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding AiNarrative}" TextWrapping="Wrap"
                                   FontSize="13" Foreground="{DynamicResource ThemeForeground}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
