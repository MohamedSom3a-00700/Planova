<UserControl x:Class="Planova.UI.Views.AI.AssistantPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="320">
    <Grid>
        <Border x:Name="CollapsedIndicator"
                Style="{DynamicResource AIAssistantCollapsedStyle}"
                Visibility="{Binding IsExpanded, Converter={StaticResource InverseBoolToVis}}"
                MouseLeftButtonUp="OnCollapsedClick">
            <ui:SymbolIcon Symbol="Sparkle24"
                           FontSize="20"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
        </Border>

        <Border x:Name="ExpandedPanel"
                Style="{DynamicResource AIAssistantPanelStyle}"
                Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource BrandElevationLow}"
                        Padding="{DynamicResource BrandSpacingMedium}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Width="36" Height="36" CornerRadius="18" Background="{DynamicResource ThemeCard}" Margin="0,0,12,0">
                            <ui:SymbolIcon Symbol="Sparkle24"
                                           FontSize="18"
                                           Foreground="{DynamicResource ThemeAccent}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}"
                                       FontWeight="SemiBold"
                                       FontSize="{DynamicResource BrandSubheaderSize}"
                                       Foreground="{DynamicResource BrandHeaderForeground}"
                                       FontFamily="{DynamicResource BrandFontFamily}" />
                            <TextBlock Text="{Binding StatusText}"
                                       FontSize="{DynamicResource BrandCaptionSize}"
                                       Foreground="{DynamicResource BrandTextSecondary}"
                                       FontFamily="{DynamicResource BrandFontFamily}" />
                        </StackPanel>

                        <ui:Button Grid.Column="2"
                                   Background="Transparent"
                                   Foreground="{DynamicResource BrandTextSecondary}"
                                   BorderThickness="0"
                                   Command="{Binding ToggleExpandCommand}"
                                   Padding="4"
                                   Width="28"
                                   Height="28"
                                   ToolTip="Collapse AI panel">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="Dismiss24" />
                            </ui:Button.Icon>
                        </ui:Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1"
                              Background="{DynamicResource ThemeSurface}"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock Text="{Binding StatusText}"
                                   Style="{DynamicResource BodyTextStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />

                        <Border Style="{DynamicResource CardSurfaceStyle}" Padding="12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="AI assistant"
                                           Style="{DynamicResource SectionHeaderStyle}"
                                           Margin="0,0,0,4" />
                                <TextBlock Text="Supportive planning, reporting, and workspace guidance will surface here."
                                           Style="{DynamicResource BodyTextStyle}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Background="{DynamicResource ThemeSurface}"
                        BorderBrush="{DynamicResource ThemeBorder}"
                        BorderThickness="0,1,0,0"
                        Padding="8,4">
                    <ui:TextBox Text=""
                                PlaceholderText="Ask Planova AI"
                                ClearButtonEnabled="True"
                                Margin="4"
                                Padding="8,6">
                        <ui:TextBox.Icon>
                            <ui:SymbolIcon Symbol="Chat24" />
                        </ui:TextBox.Icon>
                    </ui:TextBox>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
