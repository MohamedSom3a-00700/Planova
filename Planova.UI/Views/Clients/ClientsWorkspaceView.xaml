<UserControl x:Class="Planova.UI.Views.Clients.ClientsWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels"
             xmlns:conv="clr-namespace:Planova.UI.Converters"
             d:DataContext="{d:DesignInstance vm:ClientsWorkspaceViewModel}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToVisibilityConverter x:Key="InvertedBoolToVis" Invert="True"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="12">
            <TextBlock Text="Clients" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource ThemeForeground}"/>
            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Width="250" Height="28"/>
                <Button Content="Search" Command="{Binding SearchCommand}" Margin="8,0,0,0" Height="28"/>
                <Button Content="+ New Client" Command="{Binding NewClientCommand}" Margin="12,0,0,0" Height="28"/>
            </StackPanel>
            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="12,0,12,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <ListView Grid.Column="0" ItemsSource="{Binding Clients}"
                      SelectedItem="{Binding SelectedClient, Mode=TwoWay}"
                      Background="{DynamicResource ThemeSurface}" BorderThickness="1">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Code" DisplayMemberBinding="{Binding Code}" Width="80"/>
                        <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="150"/>
                        <GridViewColumn Header="Email" DisplayMemberBinding="{Binding ContactEmail}" Width="150"/>
                        <GridViewColumn Header="Projects" DisplayMemberBinding="{Binding ProjectCount}" Width="70"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <ScrollViewer Grid.Column="1" Margin="12,0,0,0"
                          Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="{Binding SelectedClient.Name, TargetNullValue='New Client'}"
                               FontSize="18" FontWeight="SemiBold"/>
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Code:" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EditCode}" Margin="4,2"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Name:" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding EditName}" Margin="4,2"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Email:" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding EditContactEmail}" Margin="4,2"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Phone:" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding EditContactPhone}" Margin="4,2"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Organization:"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding EditOrganizationDetails}" AcceptsReturn="True" Height="50" Margin="4,2"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Notes:"/>
                        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding EditNotes}" AcceptsReturn="True" Height="50" Margin="4,2"/>
                        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Save" Command="{Binding SaveCommand}" Height="28" Width="80"/>
                            <Button Content="Cancel" Command="{Binding CancelEditCommand}" Margin="8,0,0,0" Height="28" Width="80"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Column="1" Margin="12,0,0,0"
                        Visibility="{Binding IsEditing, Converter={StaticResource InvertedBoolToVis}}">
                <StackPanel Visibility="{Binding SelectedClient, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding SelectedClient.Name, StringFormat='Client: {0}'}"
                               FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding SelectedClient.Code, StringFormat='Code: {0}'}" Margin="0,4"/>
                    <TextBlock Text="{Binding SelectedClient.ContactEmail, StringFormat='Email: {0}'}" Margin="0,4"/>
                    <TextBlock Text="{Binding SelectedClient.ContactPhone, StringFormat='Phone: {0}'}" Margin="0,4"/>
                    <TextBlock Text="{Binding SelectedClient.OrganizationDetails}" TextWrapping="Wrap" Margin="0,8"/>

                    <TextBlock Text="Linked Projects" FontSize="14" FontWeight="SemiBold" Margin="0,12,0,4"/>
                    <ItemsControl ItemsSource="{Binding SelectedClient.Projects}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" Margin="0,2"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="Edit" Command="{Binding EditClientCommand}" Height="28" Width="80"/>
                        <Button Content="Delete" Command="{Binding DeleteCommand}" Margin="8,0,0,0" Height="28" Width="80"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
