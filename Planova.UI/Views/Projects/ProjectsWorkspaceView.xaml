<UserControl x:Class="Planova.UI.Views.Projects.ProjectsWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels"
             xmlns:conv="clr-namespace:Planova.UI.Converters"
             xmlns:ui="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
             d:DataContext="{d:DesignInstance vm:ProjectsWorkspaceViewModel}"
             Background="{DynamicResource WorkspaceBackgroundGradient}"
             FontFamily="{DynamicResource BrandFontFamily}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToVisibilityConverter x:Key="InvertedBoolToVis" Invert="True"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="12">
            <TextBlock Text="Projects" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource ThemeForeground}"/>
            <WrapPanel Margin="0,12,0,0">
                <ui:TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="Search projects..."
                            ClearButtonEnabled="True"
                            Width="250" Height="28"/>
                <Button Content="Search" Command="{Binding SearchCommand}" Margin="8,0,0,0" Height="28"/>
                <ComboBox ItemsSource="{Binding StatusFilters}" SelectedItem="{Binding SelectedStatusFilter}"
                          Margin="8,0,0,0" Height="28" Width="120"/>
                <Button Content="+ New Project" Command="{Binding NewProjectCommand}" Margin="12,0,0,0" Height="28"/>
            </WrapPanel>
            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="12,0,12,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <ListView Grid.Column="0" ItemsSource="{Binding Projects}"
                      SelectedItem="{Binding SelectedSummary, Mode=TwoWay}"
                      Background="{DynamicResource ThemeSurface}" BorderThickness="1">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Code" DisplayMemberBinding="{Binding Code}" Width="80"/>
                        <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="150"/>
                        <GridViewColumn Header="Status" DisplayMemberBinding="{Binding Status}" Width="90"/>
                        <GridViewColumn Header="Client" DisplayMemberBinding="{Binding ClientName}" Width="120"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <ScrollViewer Grid.Column="1" Margin="12,0,0,0"
                          Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="{Binding SelectedProject.Name, TargetNullValue='New Project'}"
                               FontSize="18" FontWeight="SemiBold"/>
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Code:" VerticalAlignment="Center"/>
                        <ui:TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EditCode}"
                                    PlaceholderText="Enter project code" Height="28" Margin="4,2"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Name:" VerticalAlignment="Center"/>
                        <ui:TextBox Grid.Row="1" Grid.Column="1" Text="{Binding EditName}"
                                    PlaceholderText="Enter project name" Height="28" Margin="4,2"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Description:" VerticalAlignment="Top" Margin="0,8,0,0"/>
                        <ui:TextBox Grid.Row="2" Grid.Column="1" Text="{Binding EditDescription}"
                                    PlaceholderText="Enter description" AcceptsReturn="True" Height="50" Margin="4,2"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Start Date:" VerticalAlignment="Center"/>
                        <DatePicker Grid.Row="3" Grid.Column="1" SelectedDate="{Binding EditStartDate}" Height="28" Margin="4,2"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Finish Date:" VerticalAlignment="Center"/>
                        <DatePicker Grid.Row="4" Grid.Column="1" SelectedDate="{Binding EditFinishDate}" Height="28" Margin="4,2"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Currency:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="5" Grid.Column="1" ItemsSource="{Binding Currencies}" SelectedItem="{Binding EditCurrency}" Height="28" Margin="4,2" IsEditable="False"/>
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Client:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="6" Grid.Column="1" ItemsSource="{Binding Clients}" DisplayMemberPath="Name"
                                  SelectedValuePath="Id" SelectedValue="{Binding EditClientId}" Height="28" Margin="4,2"/>
                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Main Contractor:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="7" Grid.Column="1" ItemsSource="{Binding Contractors}" DisplayMemberPath="Name"
                                  SelectedValuePath="Id" SelectedValue="{Binding EditContractorId}" Height="28" Margin="4,2"/>
                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Subcontractor:" VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="8" Grid.Column="1" ItemsSource="{Binding Subcontractors}" DisplayMemberPath="Name"
                                  SelectedValuePath="Id" SelectedValue="{Binding EditSubcontractorId}" Height="28" Margin="4,2"/>
                        <TextBlock Grid.Row="9" Grid.Column="0" Text="Notes:" VerticalAlignment="Top" Margin="0,8,0,0"/>
                        <ui:TextBox Grid.Row="9" Grid.Column="1" Text="{Binding EditNotes}"
                                    PlaceholderText="Enter notes" AcceptsReturn="True" Height="50" Margin="4,2"/>
                        <StackPanel Grid.Row="10" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Save" Command="{Binding SaveCommand}" Height="28" Width="80"/>
                            <Button Content="Cancel" Command="{Binding CancelEditCommand}" Margin="8,0,0,0" Height="28" Width="80"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Grid.Column="1" Margin="12,0,0,0" VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsEditing, Converter={StaticResource InvertedBoolToVis}}">
                <StackPanel Visibility="{Binding SelectedProject, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding SelectedProject.Name, StringFormat='Project: {0}'}"
                               FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding SelectedProject.Code, StringFormat='Code: {0}'}" Margin="0,4"/>
                    <TextBlock Text="{Binding SelectedProject.Status, StringFormat='Status: {0}'}" Margin="0,4"/>
                    <TextBlock Text="{Binding SelectedProject.ClientName, StringFormat='Client: {0}'}" Margin="0,4"/>
                    <TextBlock Text="{Binding SelectedProject.Description}" TextWrapping="Wrap" Margin="0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="Edit" Command="{Binding EditProjectCommand}" Height="28" Width="80"/>
                        <Button Content="Delete" Command="{Binding DeleteCommand}" Margin="8,0,0,0" Height="28" Width="80"/>
                    </StackPanel>
                    <TextBlock Text="Status Transitions" FontSize="14" FontWeight="SemiBold" Margin="0,16,0,4"/>
                    <ItemsControl ItemsSource="{Binding SelectedProject.AllowedNextStatuses}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}" Margin="0,0,4,4" Height="26"
                                        Command="{Binding DataContext.ChangeStatusCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
