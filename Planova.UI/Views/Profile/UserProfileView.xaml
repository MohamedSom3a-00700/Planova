<UserControl x:Class="Planova.UI.Views.Profile.UserProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels"
             xmlns:conv="clr-namespace:Planova.UI.Converters"
             d:DataContext="{d:DesignInstance vm:UserProfileViewModel}"
             Background="{DynamicResource WorkspaceBackgroundGradient}"
             FontFamily="{DynamicResource BrandFontFamily}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <ScrollViewer>
        <StackPanel Margin="24">
            <TextBlock Text="Profile" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource ThemeForeground}"/>

            <Grid Margin="0,24,0,0" Width="500" HorizontalAlignment="Left">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Display Name:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding DisplayName}" Margin="4,2"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Role:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding RoleLabel}" Margin="4,2"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Organization:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding OrganizationName}" Margin="4,2"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Theme:" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="3" Grid.Column="1" SelectedValue="{Binding ThemePreference}" SelectedValuePath="Content" Margin="4,2">
                    <ComboBoxItem Content="Dark"/>
                    <ComboBoxItem Content="Light"/>
                </ComboBox>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Language:" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="4" Grid.Column="1" SelectedValue="{Binding LanguagePreference}" SelectedValuePath="Content" Margin="4,2">
                    <ComboBoxItem Content="en"/>
                    <ComboBoxItem Content="ar"/>
                </ComboBox>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Default Workspace:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding DefaultWorkspace}" Margin="4,2"/>

                <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,16,0,0">
                    <Button Content="Save" Command="{Binding SaveCommand}" Height="28" Width="100"/>
                </StackPanel>

                <TextBlock Grid.Row="7" Grid.ColumnSpan="2"
                           Text="Profile saved successfully!" Foreground="Green"
                           Visibility="{Binding IsSaved, Converter={StaticResource BoolToVis}}"
                           Margin="0,8,0,0"/>
            </Grid>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                       Margin="0,8,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
