<UserControl x:Class="Planova.UI.Views.Activity.ActivityStudioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels.Activity"
             xmlns:shared="clr-namespace:Planova.UI.Views.Shared"
             d:DataContext="{d:DesignInstance vm:ActivityStudioViewModel}"
             Background="{DynamicResource WorkspaceBackgroundGradient}"
             FontFamily="{DynamicResource BrandFontFamily}"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="12,12,12,0">
            <TextBlock Text="Activity Studio" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource ThemeForeground}"/>
            <shared:DocumentValidationBannerView DataContext="{Binding DocumentValidationBanner}"/>
            <TextBlock TextWrapping="Wrap" Margin="0,4,0,0" Foreground="Gray" FontSize="13">
                Create and manage project schedule activities, define logic relationships (FS/SS/FF/SF),
                manage calendars, browse the Activity Bank, generate activities from WBS/BOQ, and export reports.
                Use the tabs below to navigate between modules.
            </TextBlock>
        </StackPanel>

        <TabControl Grid.Row="1" ItemsSource="{Binding Tabs}"
                    SelectedItem="{Binding SelectedTab}"
                    Margin="12,8,12,12">
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Header}"/>
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <ContentControl Content="{Binding Content}"/>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </Grid>
</UserControl>
