<UserControl x:Class="Planova.UI.Views.NavigationRail"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Width="220"
             Background="{DynamicResource ThemeSurface}">
    <StackPanel>
        <Button x:Name="ToggleButton" Content="☰" Width="220" Height="48"
                Background="Transparent"
                Foreground="{DynamicResource ThemeForeground}"
                BorderThickness="0"
                Click="OnToggleClick" />
        <ItemsControl x:Name="NavItems"
                      ItemsSource="{Binding NavigationItems}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Content="{Binding DisplayName}" Height="40" Margin="6,2"
                            Background="Transparent"
                            Foreground="{DynamicResource ThemeForeground}"
                            BorderThickness="0"
                            HorizontalContentAlignment="Left"
                            Padding="12,0"
                            Command="{Binding Command}"
                            CommandParameter="{Binding CommandParameter}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
