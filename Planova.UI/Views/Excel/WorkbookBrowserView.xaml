<UserControl x:Class="Planova.UI.Views.Excel.WorkbookBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels.Excel"
             xmlns:conv="clr-namespace:Planova.UI.Converters"
             d:DataContext="{d:DesignInstance vm:WorkbookBrowserViewModel}"
             Background="{DynamicResource WorkspaceBackgroundGradient}"
             FontFamily="{DynamicResource BrandFontFamily}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToVisibilityConverter x:Key="InvertedBoolToVis" Invert="True"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="12">
            <TextBlock Text="Workbook Browser" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource ThemeForeground}"/>
            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <TextBox Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}"
                         Width="300" Height="28"/>
                <Button Content="Browse" Command="{Binding BrowseCommand}" Margin="8,0,0,0" Height="28"/>
                <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Width="200" Margin="12,0,0,0" Height="28"/>
                <Button Content="Search" Command="{Binding SearchWorksheetCommand}" Margin="4,0,0,0" Height="28"/>
            </StackPanel>
            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="12,0,12,0" MaxHeight="120"
              Visibility="{Binding WorkbookInfo, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding WorkbookInfo.FilePath, StringFormat='File: {0}'}" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding WorkbookInfo.FileSize, StringFormat='Size: {0:N0} bytes'}"/>
                <TextBlock Text="{Binding WorkbookInfo.Format, StringFormat='Format: {0}'}"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
                <TextBlock Text="Worksheets" FontWeight="SemiBold"/>
                <ListView ItemsSource="{Binding WorkbookInfo.Worksheets}"
                          SelectedItem="{Binding SelectedWorksheet, Mode=TwoWay}"
                          MaxHeight="80">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
            <StackPanel Grid.Column="2" Visibility="{Binding SearchResults.Count, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Search Results" FontWeight="SemiBold"/>
                <ItemsControl ItemsSource="{Binding SearchResults}" MaxHeight="80"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2" Margin="12"
              Visibility="{Binding PreviewData, Converter={StaticResource BoolToVis}}">
            <DataGrid ItemsSource="{Binding PreviewRows}"
                      AutoGenerateColumns="True"
                      IsReadOnly="True"
                      Background="{DynamicResource ThemeSurface}"
                      BorderThickness="1"
                      CanUserResizeColumns="True"
                      VirtualizingPanel.ScrollUnit="Pixel"
                      EnableRowVirtualization="True"
                      RowHeight="24"/>
        </Grid>

        <StackPanel Grid.Row="3" Margin="12"
                    Orientation="Horizontal"
                    Visibility="{Binding PreviewData, Converter={StaticResource BoolToVis}}">
            <Button Content="Previous" Command="{Binding PreviousPageCommand}" Height="28" MinWidth="70"
                    IsEnabled="{Binding CurrentPage, Converter={StaticResource BoolToVis}}"/>
            <TextBlock Text="{Binding CurrentPage, StringFormat='Page {0}'}"
                       VerticalAlignment="Center" Margin="12,0"/>
            <TextBlock Text="{Binding TotalPages, StringFormat='of {0}'}"
                       VerticalAlignment="Center"/>
            <Button Content="Next" Command="{Binding NextPageCommand}" Height="28" MinWidth="70" Margin="12,0,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
