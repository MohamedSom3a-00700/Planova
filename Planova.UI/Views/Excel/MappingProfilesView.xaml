<UserControl x:Class="Planova.UI.Views.Excel.MappingProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels.Excel"
             xmlns:conv="clr-namespace:Planova.UI.Converters"
             d:DataContext="{d:DesignInstance vm:MappingProfilesViewModel}"
             Background="{DynamicResource WorkspaceBackgroundGradient}"
             FontFamily="{DynamicResource BrandFontFamily}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="12">
            <TextBlock Text="Mapping Profiles" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource ThemeForeground}"/>
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <ComboBox ItemsSource="{Binding EntityTypes}" SelectedItem="{Binding SelectedEntityType}"
                          Width="150" Height="28"/>
                <Button Content="Load" Command="{Binding LoadProfilesCommand}"
                        CommandParameter="{Binding SelectedEntityType}"
                        Margin="8,0,0,0" Height="28"/>
            </StackPanel>
            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="12,0,12,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <ListView Grid.Column="0" ItemsSource="{Binding Profiles}"
                      SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                      Background="{DynamicResource ThemeSurface}" BorderThickness="1">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="120"/>
                        <GridViewColumn Header="Version" DisplayMemberBinding="{Binding Version}" Width="60"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                <StackPanel Visibility="{Binding SelectedProfile, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding SelectedProfile.Name}" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding SelectedProfile.EntityType, StringFormat='Entity: {0}'}"/>
                    <TextBlock Text="{Binding SelectedProfile.Version, StringFormat='Version: {0}'}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="Edit" Command="{Binding StartEditingCommand}" Height="28" MinWidth="70"/>
                        <Button Content="Delete" Command="{Binding DeleteProfileCommand}" Height="28" MinWidth="70" Margin="8,0,0,0"/>
                    </StackPanel>
                    <StackPanel Margin="0,12,0,0" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Edit name:" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" Width="200" Height="28" Margin="0,4,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Save" Command="{Binding UpdateProfileCommand}" Height="28" MinWidth="70"/>
                            <Button Content="Cancel" Command="{Binding CancelEditingCommand}" Height="28" MinWidth="70" Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Margin="0,16,0,0">
                    <TextBlock Text="Create new profile" FontSize="14" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" Width="200" Height="28" Margin="0,4,0,0"/>
                    <Button Content="Create" Command="{Binding CreateProfileCommand}" Height="28" MinWidth="70" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Margin="0,16,0,0" Visibility="{Binding SelectedProfile, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Clone profile" FontSize="14" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding CloneName, UpdateSourceTrigger=PropertyChanged}" Width="200" Height="28" Margin="0,4,0,0"/>
                    <Button Content="Clone" Command="{Binding CloneProfileCommand}" Height="28" MinWidth="70" Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
