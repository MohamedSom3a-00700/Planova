<UserControl x:Class="Planova.UI.Views.Excel.ExportWizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels.Excel"
             xmlns:conv="clr-namespace:Planova.UI.Converters"
             d:DataContext="{d:DesignInstance vm:ExportViewModel}"
             Background="{DynamicResource WorkspaceBackgroundGradient}"
             FontFamily="{DynamicResource BrandFontFamily}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="12">
            <TextBlock Text="Export Wizard" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource ThemeForeground}"/>
            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="12">
            <TextBlock Text="Select entity type to export" FontSize="16"/>
            <ComboBox ItemsSource="{Binding EntityTypes}" SelectedItem="{Binding SelectedEntityType}"
                      Width="250" Margin="0,8,0,0"/>

            <StackPanel Margin="0,16,0,0"
                        Visibility="{Binding ExportRequest, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Selected columns to export" FontWeight="SemiBold"/>
                <ListBox ItemsSource="{Binding SelectedColumns}" MaxHeight="150" Margin="0,4,0,0"/>
                <TextBlock Text="Output file path:" FontWeight="SemiBold" Margin="0,12,0,0"/>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBox Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}" Width="300" Height="28"/>
                    <Button Content="Browse" Command="{Binding BrowseOutputPathCommand}" Margin="8,0,0,0" Height="28"/>
                </StackPanel>
            </StackPanel>

            <ProgressBar Value="{Binding ExportProgress}" Height="20" Margin="0,12,0,0"
                         Visibility="{Binding ExportResult, Converter={StaticResource BoolToVis}}"/>
            <StackPanel Visibility="{Binding ExportResult, Converter={StaticResource BoolToVis}}" Margin="0,8,0,0">
                <TextBlock Text="{Binding ExportResult.TotalRecords, StringFormat='Exported: {0} records'}"/>
                <TextBlock Text="{Binding ExportResult.OutputPath, StringFormat='Saved to: {0}'}"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="12" Orientation="Horizontal">
            <Button Content="Export" Command="{Binding ExportCommand}" Height="28" MinWidth="70"/>
            <Button Content="Reset" Command="{Binding ResetCommand}" Height="28" MinWidth="70" Margin="8,0,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
