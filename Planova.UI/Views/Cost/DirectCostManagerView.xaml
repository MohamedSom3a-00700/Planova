<UserControl x:Class="Planova.UI.Views.Cost.DirectCostManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels.Cost"
             d:DataContext="{d:DesignInstance vm:DirectCostManagerViewModel}"
             Background="{DynamicResource WorkspaceBackgroundGradient}"
             FontFamily="{DynamicResource BrandFontFamily}"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Direct Costs" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource ThemeForeground}" Margin="0,0,0,8"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Add Direct Cost" Command="{Binding AddDirectCostCommand}" Margin="0,0,8,0"
                    FontFamily="{DynamicResource BrandFontFamily}"/>
            <Button Content="Edit" Command="{Binding EditDirectCostCommand}" Margin="0,0,8,0"
                    FontFamily="{DynamicResource BrandFontFamily}"/>
            <Button Content="Delete" Command="{Binding DeleteDirectCostCommand}"
                    FontFamily="{DynamicResource BrandFontFamily}"/>
        </StackPanel>

        <DataGrid Grid.Row="2" ItemsSource="{Binding DirectCosts}"
                  SelectedItem="{Binding SelectedDirectCost, Mode=TwoWay}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  Background="{DynamicResource ThemeBackgroundMedium}"
                  BorderBrush="{DynamicResource ThemeBorder}"
                  FontFamily="{DynamicResource BrandFontFamily}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="80"/>
                <DataGridTextColumn Header="UOM" Binding="{Binding UnitOfMeasure}" Width="60"/>
                <DataGridTextColumn Header="Rate" Binding="{Binding UnitRate}" Width="80"/>
                <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount}" Width="100"/>
                <DataGridTextColumn Header="Scope" Binding="{Binding Scope}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
