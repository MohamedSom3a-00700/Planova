<UserControl x:Class="Planova.UI.Views.Cost.BudgetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels.Cost"
             d:DataContext="{d:DesignInstance vm:BudgetViewModel}"
             Background="{DynamicResource WorkspaceBackgroundGradient}"
             FontFamily="{DynamicResource BrandFontFamily}"
             mc:Ignorable="d">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Budget Management" FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource ThemeForeground}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <TextBlock Text="Resource Cost Total:" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Budget.ResourceCostTotal, StringFormat={}{0:N2}}"/>

                <TextBlock Text="Direct Cost Total:" FontWeight="SemiBold" Margin="0,8,0,0"/>
                <TextBlock Text="{Binding Budget.DirectCostTotal, StringFormat={}{0:N2}}"/>

                <TextBlock Text="Contingency Amount:" FontWeight="SemiBold" Margin="0,8,0,0"/>
                <TextBox Text="{Binding ContingencyAmount}" Margin="0,4,0,0"/>

                <TextBlock Text="Contingency %:" FontWeight="SemiBold" Margin="0,8,0,0"/>
                <TextBox Text="{Binding ContingencyPercent}" Margin="0,4,0,0"/>

                <CheckBox Content="Manual Override" IsChecked="{Binding IsManualOverride}" Margin="0,12,0,0"/>

                <TextBlock Text="Manual Total Budget:" FontWeight="SemiBold" Margin="0,8,0,0"/>
                <TextBox Text="{Binding ManualTotal}" IsEnabled="{Binding IsManualOverride}" Margin="0,4,0,0"/>

                <TextBlock Text="Total Budget:" FontWeight="Bold" FontSize="16" Margin="0,12,0,0"/>
                <TextBlock Text="{Binding Budget.TotalBudget, StringFormat={}{0:N2}}" FontSize="14"/>

                <Button Content="Save" Command="{Binding SaveCommand}" Margin="0,12,0,0"
                        FontFamily="{DynamicResource BrandFontFamily}"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
