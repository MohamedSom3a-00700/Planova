<UserControl x:Class="Planova.UI.Views.Cost.CashFlowView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels.Cost"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             d:DataContext="{d:DesignInstance vm:CashFlowViewModel}"
             Background="{DynamicResource WorkspaceBackgroundGradient}"
             FontFamily="{DynamicResource BrandFontFamily}"
             mc:Ignorable="d">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Cash Flow" FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource ThemeForeground}"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="{Binding SelectedPeriodType, StringFormat='Toggle to {0}'}"
                    Command="{Binding TogglePeriodTypeCommand}" Margin="0,0,8,0"
                    FontFamily="{DynamicResource BrandFontFamily}"/>
        </StackPanel>

        <lvc:CartesianChart Grid.Row="2"
                            Series="{Binding Series}"
                            XAxes="{Binding XAxes}"
                            YAxes="{Binding YAxes}"
                            Margin="0,0,0,8"
                            Background="{DynamicResource ThemeBackgroundMedium}"/>

        <DataGrid Grid.Row="3" ItemsSource="{Binding Periods}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  Background="{DynamicResource ThemeBackgroundMedium}"
                  BorderBrush="{DynamicResource ThemeBorder}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Period Start" Binding="{Binding PeriodStart}" Width="120"/>
                <DataGridTextColumn Header="Period End" Binding="{Binding PeriodEnd}" Width="120"/>
                <DataGridTextColumn Header="Planned" Binding="{Binding PlannedCost}" Width="100"/>
                <DataGridTextColumn Header="Actual" Binding="{Binding ActualCost}" Width="100"/>
                <DataGridTextColumn Header="Cum. Planned" Binding="{Binding CumulativePlanned}" Width="120"/>
                <DataGridTextColumn Header="Cum. Actual" Binding="{Binding CumulativeActual}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
