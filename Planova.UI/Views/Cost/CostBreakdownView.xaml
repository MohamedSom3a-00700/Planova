<UserControl x:Class="Planova.UI.Views.Cost.CostBreakdownView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels.Cost"
             d:DataContext="{d:DesignInstance vm:CostBreakdownViewModel}"
             Background="{DynamicResource WorkspaceBackgroundGradient}"
             FontFamily="{DynamicResource BrandFontFamily}"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Cost Breakdown" FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource ThemeForeground}"/>
        </StackPanel>

        <TreeView Grid.Row="1" ItemsSource="{Binding TreeItems}"
                  SelectedItemChanged="OnSelectedItemChanged"
                  Background="{DynamicResource ThemeBackgroundMedium}"
                  BorderThickness="1"
                  BorderBrush="{DynamicResource ThemeBorder}">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal" Margin="2">
                        <TextBlock Text="{Binding Label}" FontWeight="SemiBold" Margin="0,0,12,0"/>
                        <TextBlock Text="{Binding PlannedCost, StringFormat={}{0:N2}}" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding ActualCost, StringFormat={}{0:N2}}" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Variance, StringFormat={}{0:N2}}"/>
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</UserControl>
