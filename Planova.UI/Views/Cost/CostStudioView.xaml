<UserControl x:Class="Planova.UI.Views.Cost.CostStudioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Planova.UI.ViewModels.Cost"
             d:DataContext="{d:DesignInstance vm:CostStudioViewModel}"
             Background="{DynamicResource WorkspaceBackgroundGradient}"
             FontFamily="{DynamicResource BrandFontFamily}"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="12,12,12,0">
            <TextBlock Text="Cost Studio" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource ThemeForeground}"/>
        </StackPanel>

        <TabControl Grid.Row="1" Margin="12"
                    ItemsSource="{Binding Tabs}"
                    SelectedItem="{Binding SelectedTab, Mode=TwoWay}"
                    Background="Transparent"
                    BorderThickness="0">
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Header}" FontFamily="{DynamicResource BrandFontFamily}"/>
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <ContentControl Content="{Binding Content}"
                                    Focusable="False"
                                    Background="{DynamicResource WorkspaceBackgroundGradient}"/>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </Grid>
</UserControl>
